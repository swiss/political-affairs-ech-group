<https://register.ld.admin.ch/i14y/concept/personAliasName> a owl:Class ;
    rdfs:label "PersonAliasName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """According to the official character catalogue (No. 215) for the harmonisation of registers: Name (e.g. stage name, religious name) which, on the basis of an accepted application, may be used by the person. The alias name may consist of one or more parts (e.g. also the alias first name and alias surname).
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 215) Registerharmonisierung: Name (z. B. Künstler- oder Ordensname), der aufgrund eines bewilligten Gesuchs geführt werden darf. Der Aliasname kann aus einem oder mehreren Teilen (z. B. auch aus Aliasvorname und Aliasname) bestehen.
""" .

<https://register.ld.admin.ch/i14y/concept/personAllianceName> a owl:Class ;
    rdfs:label "PersonAllianceName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """According to the official catalogue of characters (No. 213) for the harmonisation of registers: The alliance name shows the connection between two people who are married or living in a registered partnership. An alliance name that has already been used may be retained after the dissolution of the marriage or partnership if the official name has not been changed upon dissolution. It is attached to the official name with a hyphen and is formed with the partner's maiden name or the person's own maiden name. Upon request, the alliance name may be entered in the passport or on the identity card.
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 213) Registerharmonisierung: Der Allianzname zeigt die Verbindung von zwei Personen auf, die verheiratet sind oder in einer eingetragenen Partnerschaft leben. Ein bereits verwendeter Allianzname kann nach Auflösung der Ehe oder der Partnerschaft weiterverwendet werden, wenn der amtliche Name bei der Auflösung nicht geändert wurde. Dabei wird dem amtlichen Namen mittels Bindestrich der Ledigname des Partners/der Partnerin oder der eigene Ledigname angehängt. Der Allianzname kann auf Antrag im Pass oder auf der Identitätskarte eingetragen werden.
""" .

<https://register.ld.admin.ch/i14y/concept/personCallFirstName> a owl:Class ;
    rdfs:label "PersonCallFirstName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """A person has the right to choose a common first name from the list of their official first names. The common first name may consist of one or more first names (from those listed under ‘official first names’).
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 222) Registerharmonisierung: Eine Person hat das Recht, aus der Liste ihrer amtlichen Vornamen einen Rufnamen auszuwählen. Der Rufname kann aus einem oder mehreren Vornamen (aus den "amtlichen Vornamen") bestehen.
""" .

<https://register.ld.admin.ch/i14y/concept/personDeclaredForeignerFirstName> a owl:Class ;
    rdfs:label "PersonDeclaredForeignerFirstName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """For persons of foreign nationality who do not have official documents (mainly in the field of asylum). To be used in combination with the defined Name according to declaration.
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 224) Registerharmonisierung: Für Personen mit ausländischer Nationalität, die keine amtlichen Dokumente besitzen (hauptsächlich im Asylbereich). Zu benutzen in Verbindung mit dem Namen gemäss Deklaration.
""" .

<https://register.ld.admin.ch/i14y/concept/personDeclaredForeignerName> a owl:Class ;
    rdfs:label "PersonDeclaredForeignerName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """According to the official catalogue of characters (No. 217) for the harmonisation of registers: For foreign nationals who do not have official documents (mainly in the field of asylum).
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 217) Registerharmonisierung: Für Personen mit ausländischer Nationalität, die keine offiziellen Dokumente besitzen (hauptsächlich im Asylbereich).
""" .

<https://register.ld.admin.ch/i14y/concept/personFirstName> a owl:Class ;
    rdfs:label "PersonFirstName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """First names taken from the birth certificate, the civil registry (Infostar) in the order in which they appear, or taken from foreign identity documents.
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 221) Registerharmonisierung: Vornamen gemäss Geburtsurkunde oder Zivilstandsregister/Infostar in der aufgeführten Reihenfolge bzw. gemäss ausländischen Ausweispapieren.
""" .

<https://register.ld.admin.ch/i14y/concept/personFirstNameOnForeignPassport> a owl:Class ;
    rdfs:label "PersonFirstNameOnForeignPassport" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """For persons of foreign nationality. To be used in combination with the name as it appears on the foreign passport.
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 223) Registerharmonisierung: Für Personen mit ausländischer Nationalität. Zu benutzen in Verbindung mit dem Namen im ausländischen Pass."
""" .

<https://register.ld.admin.ch/i14y/concept/personNameOnForeignPassport> a owl:Class ;
    rdfs:label "PersonNameOnForeignPassport" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """According to the official catalogue of characters (No. 214) for the harmonisation of registers: For persons of foreign nationality. This name corresponds to the entry marked in the machine-readable zone of the passport. If this zone includes abbreviated surnames or first names, these must, as far as possible, be recorded in full, according to the entry in the passport.
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 214) Registerharmonisierung: Für Personen mit ausländischer Nationalität. Dieser Name entspricht dem Eintrag im Reisepass gemäss der maschinenlesbaren Zone (MRZ) des Reisepasses. Enthält die MRZ abgekürzte Namen oder Vornamen, sind diese möglichst in voller Länge gemäss visuell lesbarer Zone des Ausweispapieres zu erfassen.
""" .

<https://register.ld.admin.ch/i14y/concept/personOfficialName> a owl:Class ;
    rdfs:label "PersonOfficialName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """According to the official catalogue of characters (No. 211) for the harmonisation of registers: Name according to official documents. The official name corresponds to the name appearing in the Swiss civil register. For foreign nationals with no civil status events in Switzerland, the official name corresponds to the name appearing on the foreign passport or identity card (see ‘Name according to foreign passport’ or SEM guidelines on the determination and spelling of names of foreign nationals dated 1 January 2012. If no official documents exist, see also ‘Name according to declaration’ (e.g. in the case of asylum seekers). The official name may consist of one or more parts.
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 211) Registerharmonisierung: Name gemäss amtlichen Unterlagen. Der amtliche Name entspricht dem Namen im schweizerischen Zivilstandsregister. Bei ausländischen Personen ohne Zivilstandsereignis in der Schweiz entspricht dieser Name dem Namen im ausländischen Pass oder auf der Identitätskarte (siehe 214 sowie Weisung des SEM über die Bestimmung und Schreibweise der Namen von ausländischen Staatsangehörigen vom 1. Januar 2012. Im Ausnahmefall siehe auch "Name nach Deklaration" (z. B. Asyl), wenn keine amtlichen Dokumente vorliegen). Der amtliche Name kann aus einem oder mehreren Teilen bestehen.
""" .

<https://register.ld.admin.ch/i14y/concept/personOriginalName> a owl:Class ;
    rdfs:label "PersonOriginalName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """According to the official catalogue of characters (No. 212) for the harmonisation of registers: Name of filiation according to official documents, which corresponds to the person's name before their first marriage or registered partnership. It may also be a maiden name acquired by decision to change one's name (see Art. 24, para. 2 OEC, RS 211.112.2).
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 212) Registerharmonisierung: Angestammter Name gemäss amtlichen Unterlagen, den eine Person unmittelbar vor ihrer ersten Eheschliessung oder Begründung einer eingetragenen Partnerschaft geführt hat oder, gestützt auf einen Namensänderungsentscheid, als neuen Ledignamen erworben hat (Art. 24 Abs. 2 ZStV, SR 211.112.2).
""" .

<https://register.ld.admin.ch/i14y/concept/personOtherName> a owl:Class ;
    rdfs:label "PersonOtherName" ;
    rdfs:subClassOf act:NameTypeEnum ;
    skos:definition """According to the official catalogue of characters (No. 216) for the harmonisation of registers: Other official names according to Swiss civil status documents (Art. 24, para. 3 OEC) or according to foreign documents, which are neither surnames nor first names.
""" ;
    act:description_de """Gemäss amtlichen Katalog der Merkmale (Nr. 216) Registerharmonisierung: Weitere amtliche Namen gemäss schweizerischen Zivilstandsdokumenten (Art. 24 Abs. 3 ZStV) oder ausländischen Dokumenten, welche weder Familiennamen noch Vornamen sind.
""" .

<http://schema.org/birthDate> a owl:DatatypeProperty ;
    rdfs:label "birth_date" ;
    rdfs:range xsd:date ;
    skos:definition """Exact date of birth if available and public. This field has precedence over the field `birthYear`.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Genaues Geburtsdatum, sofern verfügbar und öffentlich. Dieses Feld hat Vorrang vor dem Feld `birthYear`.
""" .

<http://schema.org/deathDate> a owl:DatatypeProperty ;
    rdfs:label "death_date" ;
    rdfs:range xsd:date ;
    skos:definition """Exact date of death.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Genaues Todesdatum.
""" .

<http://schema.org/validFrom> a owl:DatatypeProperty ;
    rdfs:label "valid_from" ;
    rdfs:range xsd:date ;
    skos:definition """The date from which the information is valid.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das Datum, ab dem die Information gültig ist.
""" .

<http://schema.org/validThrough> a owl:DatatypeProperty ;
    rdfs:label "valid_through" ;
    rdfs:range xsd:date ;
    skos:definition """The date until which the information is valid, inclusive.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das Datum, bis und mit dem die Information gültig ist.
""" .

<https://ld.ech.ch/schema/0292/meta-common/PersonReference> a owl:Class ;
    rdfs:label "PersonReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """Lightweight reference to a person with key identification data at time of linking. Preserves historical accuracy even if the person changes later.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Leichtgewichtige Referenz auf eine Person mit den wichtigsten Identifikationsmerkmalen zum Zeitpunkt der Verknüpfung. Ermöglicht historische Korrektheit auch wenn sich die Person später ändert.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateActual> a owl:DatatypeProperty ;
    rdfs:label "date_actual" ;
    rdfs:range xsd:date ;
    skos:definition """The actual date of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das tatsächliche Datum eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateCreated> a owl:DatatypeProperty ;
    rdfs:label "date_created" ;
    rdfs:range xsd:date ;
    skos:definition """The date when an entity was created.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das Datum, an dem eine Entität erstellt wurde.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateModified> a owl:DatatypeProperty ;
    rdfs:label "date_modified" ;
    rdfs:range xsd:date ;
    skos:definition """The date when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das Datum, an dem eine Entität zuletzt geändert wurde.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datePlanned> a owl:DatatypeProperty ;
    rdfs:label "date_planned" ;
    rdfs:range xsd:date ;
    skos:definition """The planned date of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das geplante Datum eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The actual date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das tatsächliche Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> a owl:DatatypeProperty ;
    rdfs:label "datetime_created" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The date and time when an entity was created.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das Datum und die Uhrzeit, an dem eine Entität erstellt wurde.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeModified> a owl:DatatypeProperty ;
    rdfs:label "datetime_modified" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The date and time when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das Datum und die Uhrzeit, an dem eine Entität zuletzt geändert wurde.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The planned date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Das geplante Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/groupLabel> a owl:DatatypeProperty ;
    rdfs:label "group_label" ;
    skos:definition """Name of the body/group at time of linking.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Name des Gremiums zum Zeitpunkt der Verknüpfung.
""" .

<https://ld.ech.ch/schema/0292/meta-common/remark> a owl:DatatypeProperty ;
    rdfs:label "remark" ;
    rdfs:range xsd:string ;
    skos:definition """Free-text remark or note for edge cases or additional context on a process step or an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Freitext-Bemerkung oder Notiz für Sonderfälle oder zusätzlichen Kontext zu einem Prozessschritt oder einer Entität.
""" .

act:Address a owl:Class ;
    rdfs:label "Address" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:addressType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:streetAddress ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:postalCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty act:postalCode ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:postalLocality ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:postalCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty act:addressURI ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:postalLocality ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:addressType ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:AddressTypeEnum ;
            owl:onProperty act:addressType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:streetAddress ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:postalLocality ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:addressURI ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:addressURI ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:streetAddress ] ;
    skos:definition """An address with a type (e.g., private address, business address) and a value.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Eine Adresse mit einem Typ (z.B. Privatadresse, Geschäftsadresse) und einem Wert.
""" .

act:Contact a owl:Class ;
    rdfs:label "Contact" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:contactType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:ContactTypeEnum ;
            owl:onProperty act:contactType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:contactType ] ;
    skos:definition """Contact information of a person indicating a type (e.g., email, LinkedIn) and a value.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Kontaktinformation einer Person mit Angabe eines Typs (z.B. E-Mail, LinkedIn) und eines Werts.
""" .

act:InterestLink a owl:Class ;
    rdfs:label "InterestLink" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:committee ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty act:interestType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:organizationUid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:interestType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:organizationAddress ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^CHE-\\d{3}\\.\\d{3}\\.\\d{3}$" ] ) ] ;
            owl:onProperty act:organizationUid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:organizationAddress ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:legalForm ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:organizationName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:functionRole ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/PersonReference> ;
            owl:onProperty act:personReference ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:committee ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:organizationUid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:legalForm ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:organizationName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:organizationAddress ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:LegalFormEnum ;
            owl:onProperty act:legalForm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:functionRole ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:organizationName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:committee ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:InterestTypeEnum ;
            owl:onProperty act:interestType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:personReference ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:personReference ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:functionRole ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification>,
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """An interest link (conflict of interest, political financing) of a person to an organization outside the actor schema.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Eine Interessenbindung (Interessenkonflikt, Politikfinanzierung) einer Person zu einer Organisation ausserhalb des Akteur-Schemas.
""" .

act:addressType a owl:ObjectProperty ;
    rdfs:label "address_type" ;
    rdfs:range act:AddressTypeEnum ;
    skos:definition """Type of address.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Typ der Adresse.
""" .

act:addressURI a owl:DatatypeProperty ;
    rdfs:label "address_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """URI of the address from the Swiss federal building address register. The layer can be accessed at https://map.geo.admin.ch/#/map?topic=ech&layers=ch.swisstopo.amtliches-gebaeudeadressverzeichnis. Example of a valid URI: https://geo.ld.admin.ch/location/address/101904050
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """URI der Adresse aus dem eidgenössischen Gebäudeadressverzeichnis. Der Layer ist zugänglich unter https://map.geo.admin.ch/#/map?topic=ech&layers=ch.swisstopo.amtliches-gebaeudeadressverzeichnis. Beispiel einer gültigen URI: https://geo.ld.admin.ch/location/address/101904050
""" .

act:authorizedToVote a owl:DatatypeProperty ;
    rdfs:label "authorized_to_vote" ;
    rdfs:range xsd:boolean ;
    skos:definition """Indicates if the person is authorized to vote in the group. Typically false for substitute members (when not deputizing), observers, secretaries, and guests.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Gibt an, ob die Person in der Gruppe stimmberechtigt ist. Typischerweise false für Ersatzmitglieder (wenn nicht im Einsatz), Beobachter/innen, Sekretär/innen und Gäste.
""" .

act:birthYear a owl:DatatypeProperty ;
    rdfs:label "birth_year" ;
    rdfs:range xsd:integer ;
    skos:definition """Year of birth. Only to be used, if there is no full `birthDate` available.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Geburtsjahr. Nur zu verwenden, wenn kein vollständiges `birthDate` vorhanden ist.
""" .

act:committee a owl:DatatypeProperty ;
    rdfs:label "committee" ;
    skos:definition """Committee or board within the organization (e.g., Verwaltungsrat, Stiftungsrat, Vorstand, Aufsichtsrat, Beirat, Geschäftsleitung).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Gremium innerhalb der Organisation (z.B. Verwaltungsrat, Stiftungsrat, Vorstand, Aufsichtsrat, Beirat, Geschäftsleitung).
""" .

act:contactType a owl:ObjectProperty ;
    rdfs:label "contact_type" ;
    rdfs:range act:ContactTypeEnum ;
    skos:definition """Type of contact information.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Typ der Kontaktinformation.
""" .

act:country a owl:DatatypeProperty ;
    rdfs:label "country" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[A-Z]{2}$" ] ) ] ;
    skos:definition """ISO 3166-1 alpha-2 country code.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """ISO 3166-1 alpha-2 Ländercode.
""" .

act:district a owl:DatatypeProperty ;
    rdfs:label "district" ;
    skos:definition """Electoral district or region.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Wahlkreis oder Wahlregion.
""" .

act:electoralDistrict a owl:ObjectProperty ;
    rdfs:label "electoral_district" ;
    rdfs:range act:ElectoralDistrict ;
    skos:definition """Link to the electoral district.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Link zum Wahlbezirk.
""" .

act:functionRole a owl:DatatypeProperty ;
    rdfs:label "function_role" ;
    skos:definition """Function or role in the organization (e.g., Präsident/in, Vizepräsident/in, Mitglied, Delegierter, Geschäftsführer/in, Berater/in).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Funktion oder Rolle in der Organisation (z.B. Präsident/in, Vizepräsident/in, Mitglied, Delegierter, Geschäftsführer/in, Berater/in).
""" .

act:genderCode a owl:ObjectProperty ;
    rdfs:label "gender_code" ;
    rdfs:range act:GenderCodeEnum ;
    skos:definition """Gender code. Recommended values: male, female, diverse.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Geschlechtscode. Empfohlene Werte: male, female, diverse .
""" .

act:groupReference a owl:ObjectProperty ;
    rdfs:label "group_reference" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/GroupReference> ;
    skos:definition """Reference to a group with snapshot data at time of linking.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Referenz auf eine Gruppe mit Snapshot-Daten zum Zeitpunkt der Verknüpfung.
""" .

act:groupType a owl:ObjectProperty ;
    rdfs:label "group_type" ;
    rdfs:range act:GroupType ;
    skos:definition """Type of group (e.g., party, commission, parliament, or similar). The exact naming and description of the group is provided via `label`.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Klasse der Gruppierung, wie z.B. Partei, Kommission, Parlament oder ähnliches. Die genaue Benennung und Beschreibung der Gruppierung wird über `label` gemacht.
""" .

act:groupTypeEnum a owl:ObjectProperty ;
    rdfs:label "group_type_enum" ;
    rdfs:range act:GroupTypeEnum ;
    skos:definition """Link to the controlled vocabulary for group types.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Link zum kontrollierten Vokabular für Gruppentypen.
""" .

act:interestType a owl:ObjectProperty ;
    rdfs:label "interest_type" ;
    rdfs:range act:InterestTypeEnum ;
    skos:definition """Type of interest link (professional activity, political office, association).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Art der Interessenbindung (Berufliche Tätigkeit, Politische Ämter, Verein).
""" .

act:isCorrespondence a owl:DatatypeProperty ;
    rdfs:label "is_correspondence" ;
    rdfs:range xsd:boolean ;
    skos:definition """Indicates if this is the preferred language.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Gibt an, ob es sich um die bevorzugte Sprache handelt.
""" .

act:isNative a owl:DatatypeProperty ;
    rdfs:label "is_native" ;
    rdfs:range xsd:boolean ;
    skos:definition """Indicates if this is the native language.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Gibt an, ob es sich um die Muttersprache handelt.
""" .

act:landingPage a owl:DatatypeProperty ;
    rdfs:label "landing_page" ;
    rdfs:range xsd:anyURI ;
    skos:definition """Website providing further information.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Website mit weiteren Informationen.
""" .

act:legalForm a owl:ObjectProperty ;
    rdfs:label "legal_form" ;
    rdfs:range act:LegalFormEnum ;
    skos:definition """Legal form of the organization. See controlled vocabulary: https://register.ld.admin.ch/i14y/concept/legalForm
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Rechtsform der Organisation. Siehe kontrolliertes Vokabular: https://register.ld.admin.ch/i14y/concept/legalForm
""" .

act:nameType a owl:ObjectProperty ;
    rdfs:label "name_type" ;
    rdfs:range act:NameTypeEnum ;
    skos:definition """Type of name according to eCH-0011 (personNameData).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Typ des Namens gemäss eCH-0011 (personNameData).
""" .

act:occupationCode a owl:DatatypeProperty ;
    rdfs:label "occupation_code" ;
    skos:definition """ISCO-19 code of the occupation.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """ISCO-19 Code der Tätigkeit.
""" .

act:organizationAddress a owl:DatatypeProperty ;
    rdfs:label "organization_address" ;
    skos:definition """Address of the organization.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Adresse der Organisation.
""" .

act:partyColor a owl:DatatypeProperty ;
    rdfs:label "party_color" ;
    skos:definition """Party color as hexadecimal value (optional for parties, e.g., "#FF0000").
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Parteifarbe als Hexadezimalwert (optional für Parteien, z.B. "#FF0000").
""" .

act:picture a owl:DatatypeProperty ;
    rdfs:label "picture" ;
    rdfs:range xsd:anyURI ;
    skos:definition """Link to an image (preferred: PNG, then JPG, then GIF).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Link zu einem Bild (bevorzugt: PNG, dann JPG, dann GIF).
""" .

act:postalCode a owl:DatatypeProperty ;
    rdfs:label "postal_code" ;
    rdfs:range xsd:integer ;
    skos:definition """Postal code.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Postleitzahl.
""" .

act:postalLocality a owl:DatatypeProperty ;
    rdfs:label "postal_locality" ;
    skos:definition """Locality.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Ort.
""" .

act:roleType a owl:ObjectProperty ;
    rdfs:label "role_type" ;
    rdfs:range act:RoleType ;
    skos:definition """Role of the person in the membership or function.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Rolle der Person in der Mitgliedschaft oder Funktion.
""" .

act:roleTypeEnum a owl:ObjectProperty ;
    rdfs:label "role_type_enum" ;
    rdfs:range act:RoleEnum ;
    skos:definition """Role of the person in the membership or function.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Rolle der Person in der Mitgliedschaft oder Funktion.
""" .

act:spatial a owl:DatatypeProperty ;
    rdfs:label "spatial" ;
    skos:definition """Spatial reference (fos-municipality number, fos-canton number, or country). Formats: municipality: ld.admin.ch/municipality/1234, canton: ld.admin.ch/canton/23, country: ld.admin.ch/country/CHE.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Räumliche Referenz (BFS-Gemeindenummer, BFS-Kantonsnummer oder Land). Formate: Gemeinde: ld.admin.ch/municipality/1234, Kanton: ld.admin.ch/canton/23, Bund: ld.admin.ch/country/CHE.
""" .

act:statutesURL a owl:DatatypeProperty ;
    rdfs:label "statutes_url" ;
    skos:definition """URL to party statutes (PDF or webpage; optional for parties).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """URL zu Parteistatuten (PDF oder Webseite; optional für Parteien).
""" .

act:streetAddress a owl:DatatypeProperty ;
    rdfs:label "street_address" ;
    skos:definition """Street address.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Strassenadresse.
""" .

act:trainingCode a owl:DatatypeProperty ;
    rdfs:label "training_code" ;
    skos:definition """ISCO-19 code of the training or education.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """ISCO-19 Code der Ausbildung oder Bildung.
""" .

act:trainingType a owl:ObjectProperty ;
    rdfs:label "training_type" ;
    rdfs:range act:TrainingTypeEnum ;
    skos:definition """Type of training or education.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Typ der Ausbildung oder Bildung.
""" .

<https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates> a owl:Class ;
    rdfs:label "HasCreationModificationDates" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ] ;
    skos:definition """A mixin class that provides slots for modeling creation and modification dates of an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von Erstellungs- und Änderungsdaten einer Entität zur Verfügung stellt.
""" .

<https://ld.ech.ch/schema/0292/meta-common/abbreviation> a owl:ObjectProperty ;
    rdfs:label "abbreviation" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:definition """Abbreviation (can be multilingual).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Abkürzung (kann mehrsprachig sein).
""" .

act:address a owl:ObjectProperty ;
    rdfs:label "addresses" ;
    rdfs:range act:Address ;
    skos:definition """Addresses with type (private, business, local).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Adressen mit Typ (privat, geschäftlich, lokal).
""" .

act:contact a owl:ObjectProperty ;
    rdfs:label "contacts" ;
    rdfs:range act:Contact ;
    skos:definition """Contact information (email, website, social media). Guideline: email is quasi-mandatory and should always be provided where available.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Kontaktinformationen (E-Mail, Website, Social Media). Richtlinie: E-Mail ist quasi-obligatorisch und sollte wenn vorhanden immer angegeben werden.
""" .

act:interestLink a owl:ObjectProperty ;
    rdfs:label "interest_links" ;
    rdfs:range act:InterestLink ;
    skos:definition """Collection of interest links.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Sammlung von Interessenbindungen.
""" .

act:AddressTypeEnum a owl:Class ;
    rdfs:label "AddressTypeEnum" ;
    owl:unionOf ( <https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#privateAddress> <https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#businessAddress> <https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#localAddress> ) ;
    skos:definition """Types of addresses.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Adresstypen.
""" ;
    linkml:permissible_values <https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#businessAddress>,
        <https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#localAddress>,
        <https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#privateAddress> .

act:GenderCodeEnum a owl:Class ;
    rdfs:label "GenderCodeEnum" ;
    owl:unionOf ( <https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#male> <https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#female> <https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#diverse> ) ;
    skos:definition """Gender codes for persons. If the gender is not known, no gender entry shall be added. The `diverse` code shall be used together with a label to provide further details about the self-identified gender.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Geschlechtscodes für Personen. Wenn das Geschlecht nicht bekannt ist, soll kein Geschlechtseintrag hinzugefügt werden. Der Code `diverse` soll zusammen mit einer Bezeichnung verwendet werden, um weitere Angaben zum selbst deklarierten Geschlecht bereitzustellen.
""" ;
    linkml:permissible_values <https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#diverse>,
        <https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#female>,
        <https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#male> .

act:InterestTypeEnum a owl:Class ;
    rdfs:label "InterestTypeEnum" ;
    owl:unionOf ( <https://ld.ech.ch/schema/0294/actors/enum/interest_type/professional_activity> <https://ld.ech.ch/schema/0294/actors/enum/interest_type/political_office> <https://ld.ech.ch/schema/0294/actors/enum/interest_type/association> ) ;
    skos:definition """Types of interest links (conflicts of interest, political financing).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Typen von Interessenbindungen (Interessenkonflikte, Politikfinanzierung).
""" ;
    linkml:permissible_values <https://ld.ech.ch/schema/0294/actors/enum/interest_type/association>,
        <https://ld.ech.ch/schema/0294/actors/enum/interest_type/political_office>,
        <https://ld.ech.ch/schema/0294/actors/enum/interest_type/professional_activity> .

<https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> a owl:Class ;
    rdfs:label "MultilingualValue" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ] ;
    skos:definition """A multilingual string with language specification.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Ein mehrsprachiger String mit Angabe der Sprache.
""" .

