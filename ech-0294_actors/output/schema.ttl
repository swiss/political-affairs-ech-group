""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Ausbildung oder Bildung einer Person mit Angabe eines Typs (z.B. Schulabschluss, Universitätsabschluss, Militärdienst), eines Labels, eines ISCO-19 Codes und der zeitlichen Gültigkeit.
""" .

<https://ld.ech.ch/schema/0294/actors/TrainingTypeEnum#military> a owl:Class ;
    rdfs:label "military" ;
