<https://ld.ech.ch/schema/0294/actors/RoleEnum#member> a owl:Class ;
    rdfs:label "member" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """Regular member (default).
""" ;
    act:description_de """Gewöhnliches Mitglied (Standard).
""" .

<https://ld.ech.ch/schema/0294/actors/RoleEnum#other> a owl:Class ;
    rdfs:label "other" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """Other role; use role_label for a descriptive label.
""" ;
    act:description_de """Andere Rolle; für eine beschreibende Bezeichnung role_label verwenden.
""" .

<https://ld.ech.ch/schema/0294/actors/RoleEnum#president> a owl:Class ;
    rdfs:label "president" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """President or chair of the group.
""" ;
    act:description_de """Präsident oder Vorsitzender der Gruppe.
""" .

<https://ld.ech.ch/schema/0294/actors/RoleEnum#stellvertreter> a owl:Class ;
    rdfs:label "stellvertreter" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """Deputy/vice role (stellvertreter).
""" ;
    act:description_de """Stellvertreter / Vize.
""" .

act:RoleType a owl:Class ;
    rdfs:label "RoleType" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:roleTypeEnum ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:RoleEnum ;
            owl:onProperty act:roleTypeEnum ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:roleTypeEnum ] ;
    skos:definition """Role of a person in a membership or function (e.g., member, president, deputy). If a role is not listed in the proposed RoleEnum vocabulary, the value 'other' can be used, and a descriptive label should be provided in the `role_label` slot. The label can also be used when a specific name is needed, even if a fitting semantic value exists in `role_type_enum`; it should be provided when `role_type_enum` is set to 'other'.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Rolle einer Person in einer Mitgliedschaft oder Funktion (z.B. Mitglied, Präsident/in, Stellvertreter/in). Wenn eine Rolle im vorgeschlagenen RoleEnum-Vokabular nicht enthalten ist, kann der Wert 'other' verwendet werden; in diesem Fall soll im Slot `role_label` eine beschreibende Bezeichnung angegeben werden. Die Bezeichnung kann auch verwendet werden, wenn eine spezifische Rollenbezeichnung nötig ist, selbst wenn in `role_type_enum` bereits ein passender semantischer Wert vorhanden ist; bei `role_type_enum = other` soll sie angegeben werden.
""" .

act:Training a owl:Class ;
    rdfs:label "Training" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom act:TrainingTypeEnum ;
            owl:onProperty act:trainingType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
