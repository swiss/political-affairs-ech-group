""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Eine URI, die auf eine Wikidata-Entität verweist, z.B. http://www.wikidata.org/entity/Q39 für die Schweiz.
""" .

act:ContactTypeEnum a owl:Class ;
