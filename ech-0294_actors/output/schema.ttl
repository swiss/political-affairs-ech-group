@prefix act: <https://ld.ech.ch/schema/0294/actors/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.ech.ch/schema/0292/meta-common/IsEventWithDuration> a owl:Class ;
    rdfs:label "IsEventWithDuration" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ] ;
    skos:definition """[de] Eine Mixin-Klasse, die Slots für die Modellierung von Ereignissen oder Vorkommnissen mit Zeitdauer zur Verfügung stellt.
[en] A mixin class that provides slots for modeling events or occurrences with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/IsInstantaneousEvent> a owl:Class ;
    rdfs:label "IsInstantaneousEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ] ;
    skos:definition """[de] Eine Mixin-Klasse, die Slots für die Modellierung von instantanen Ereignissen oder Vorkommnissen (ohne Zeitdauer) zur Verfügung stellt.
[en] A mixin class that provides slots for modeling instantaneous events or occurrences (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/multilingualValue> a owl:ObjectProperty ;
    rdfs:label "multilingual_value" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:definition """[de] Ein mehrsprachiger Wert mit Angabe der Sprache.
[en] A multilingual value with language specification.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0294/actors.owl.ttl> a owl:Ontology ;
    rdfs:label "actors-schema" ;
    dcterms:license "CC-BY" ;
    dcterms:title "Actors Schema" ;
    skos:definition """[de] Ein Schema zur Beschreibung politischer Akteure einschliesslich Personen, Gruppen, Mitgliedschaften und Interessenbindungen.
[en] A schema describing political actors including persons, groups, memberships, and interest links.
""" .

act:Container a owl:Class ;
    rdfs:label "Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom act:InterestLink ;
            owl:onProperty act:interestLink ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:interestLink ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:group ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Group ;
            owl:onProperty act:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:membership ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Membership ;
            owl:onProperty act:membership ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Person ;
            owl:onProperty act:person ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:person ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """[de] Container für politische Akteure, Gruppen und Beziehungen.
[en] Container for political actors, groups, and relationships.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:role_label a owl:DatatypeProperty ;
    rdfs:label "role_label" ;
    skos:definition """[en] Descriptive label for the role when 'other' is selected in the RoleEnum.
[de] Beschreibende Bezeichnung für die Rolle, wenn 'other' im RoleEnum ausgewählt ist.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:type_label a owl:DatatypeProperty ;
    rdfs:label "type_label" ;
    skos:definition """[en] Custom type label when standard type values don't apply.
[de] Benutzerdefinierte Typbezeichnung, wenn Standardtypwerte nicht zutreffen.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

<https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#businessAddress> a owl:Class ;
    rdfs:label "businessAddress" ;
    rdfs:subClassOf act:AddressTypeEnum ;
    skos:definition """[en] Business address.
[de] Geschäftsadresse.
""" .

<https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#localAddress> a owl:Class ;
    rdfs:label "localAddress" ;
    rdfs:subClassOf act:AddressTypeEnum ;
    skos:definition """[en] Local address.
[de] Lokaladresse.
""" .

<https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#privateAddress> a owl:Class ;
    rdfs:label "privateAddress" ;
    rdfs:subClassOf act:AddressTypeEnum ;
    skos:definition """[en] Private address.
[de] Privatadresse.
""" .

act:Citizenship a owl:Class ;
    rdfs:label "Citizenship" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:country ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[A-Z]{2}$" ] ) ] ;
            owl:onProperty act:country ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:country ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Staatsbürgerschaft einer Person mit Angabe des Landes und der zeitlichen Gültigkeit.
[en] Citizenship of a person indicating the country and temporal validity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#contact_website> a owl:Class ;
    rdfs:label "contact_website" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """[en] Contact website.
[de] Kontakt-Website.
""" .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#email> a owl:Class ;
    rdfs:label "email" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """[en] Email address.
[de] E-Mail-Adresse.
""" .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#linked_in> a owl:Class ;
    rdfs:label "linked_in" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """[en] LinkedIn profile.
[de] LinkedIn-Profil.
""" .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#twitter> a owl:Class ;
    rdfs:label "twitter" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """[en] Twitter profile.
[de] Twitter-Profil.
""" .

act:ElectoralDistrict a owl:Class ;
    rdfs:label "ElectoralDistrict" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:district ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:district ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:district ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Wahlkreis oder Wahlregion, in der eine Person politisch aktiv ist; mit zeitlicher Gültigkeit.
[en] Electoral district or region where a person is politically active; with temporal validity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:Gender a owl:Class ;
    rdfs:label "Gender" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:genderCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:genderCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:pronouns ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:pronouns ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:genderCode ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Geschlecht einer Person mit Angabe eines Geschlechtscodes und der zeitlichen Gültigkeit.
[en] Gender of a person indicating a gender code and temporal validity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:GroupType a owl:Class ;
    rdfs:label "GroupType" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:groupTypeEnum ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:GroupTypeEnum ;
            owl:onProperty act:groupTypeEnum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:groupTypeEnum ] ;
    skos:definition """[de] Art der Gruppe (z.B. Partei, Kommission, Parlament, Departement).
[en] Type of group (e.g., party, committee, parliament, department).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:LanguageProficiency a owl:Class ;
    rdfs:label "LanguageProficiency" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:isCorrespondence ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty act:isCorrespondence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:isCorrespondence ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:isNative ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty act:isNative ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:isNative ] ;
    skos:definition """[de] Sprachkenntnisse einer Person mit Angabe der Sprache und ob es sich um die bevorzugte Sprache oder die Muttersprache handelt.
[en] Language proficiency of a person indicating the language and whether it is the preferred language or native language.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:Membership a owl:Class ;
    rdfs:label "Membership" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:roleType ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Person ;
            owl:onProperty act:concernedPerson ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:concernedGroup ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:authorizedToVote ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:concernedPerson ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:concernedGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty act:authorizedToVote ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:concernedPerson ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Group ;
            owl:onProperty act:concernedGroup ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:RoleType ;
            owl:onProperty act:roleType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:authorizedToVote ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:roleType ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification>,
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Eine Mitgliedschaftsbeziehung zwischen einer Person und einer Gruppe.
[en] A membership relationship between a person and a group.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:Name a owl:Class ;
    rdfs:label "Name" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:NameTypeEnum ;
            owl:onProperty act:nameType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:nameType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:nameType ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Ein Name mit einem Typ (z.B. Rufname, amtlicher Name) und einem Wert und einer zeitlichen Gültigkeit.
[en] A name with a type (e.g., call name, official name) and a value.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:Occupation a owl:Class ;
    rdfs:label "Occupation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:occupationCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:enterprise ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:enterpriseUid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:occupationCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:enterpriseUid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:enterprise ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:enterpriseUid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:occupationCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:enterprise ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Beruf oder Tätigkeit einer Person mit Angabe eines Labels, eines ISCO-19 Codes, ob die Position bezahlt ist, und der zeitlichen Gültigkeit.
[en] Occupation or profession of a person indicating a label, an ISCO-19 code, whether the position is paid, and temporal validity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

<https://ld.ech.ch/schema/0294/actors/RoleEnum#member> a owl:Class ;
    rdfs:label "member" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """[en] Regular member (default).
[de] Gewöhnliches Mitglied (Standard).
""" .

<https://ld.ech.ch/schema/0294/actors/RoleEnum#other> a owl:Class ;
    rdfs:label "other" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """[en] Other role; use role_label for a descriptive label.
[de] Andere Rolle; für eine beschreibende Bezeichnung role_label verwenden.
""" .

<https://ld.ech.ch/schema/0294/actors/RoleEnum#president> a owl:Class ;
    rdfs:label "president" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """[en] President or chair of the group.
[de] Präsident oder Vorsitzender der Gruppe.
""" .

<https://ld.ech.ch/schema/0294/actors/RoleEnum#stellvertreter> a owl:Class ;
    rdfs:label "stellvertreter" ;
    rdfs:subClassOf act:RoleEnum ;
    skos:definition """[en] Deputy/vice role (stellvertreter).
[de] Stellvertreter / Vize.
""" .

act:RoleType a owl:Class ;
    rdfs:label "RoleType" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom act:RoleEnum ;
            owl:onProperty act:roleTypeEnum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:roleTypeEnum ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:roleTypeEnum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ] ;
    skos:definition """[de] Rolle einer Person in einer Mitgliedschaft oder Funktion (z.B. Mitglied, Präsident, Stellvertreter).
[en] Role of a person in a membership or function (e.g., member, president, deputy).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:Training a owl:Class ;
    rdfs:label "Training" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:TrainingTypeEnum ;
            owl:onProperty act:trainingType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:trainingCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:trainingType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:trainingCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:trainingType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:trainingCode ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Ausbildung oder Bildung einer Person mit Angabe eines Typs (z.B. Schulabschluss, Universitätsabschluss, Militärdienst), eines Labels, eines ISCO-19 Codes und der zeitlichen Gültigkeit.
[en] Training or education of a person indicating a type (e.g., school diploma, university degree, military service), a label, an ISCO-19 code, and temporal validity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

