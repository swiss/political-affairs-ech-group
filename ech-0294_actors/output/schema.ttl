@prefix act: <https://ld.ech.ch/schema/0294/actors/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.ech.ch/schema/0292/meta-common/IsEventWithDuration> a owl:Class ;
    rdfs:label "IsEventWithDuration" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ] ;
    skos:definition """A mixin class that provides slots for modeling events or occurrences with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von Ereignissen oder Vorkommnissen mit Zeitdauer zur Verfügung stellt.
""" .

<https://ld.ech.ch/schema/0292/meta-common/IsInstantaneousEvent> a owl:Class ;
    rdfs:label "IsInstantaneousEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ] ;
    skos:definition """A mixin class that provides slots for modeling instantaneous events or occurrences (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von instantanen Ereignissen oder Vorkommnissen (ohne Zeitdauer) zur Verfügung stellt.
""" .

<https://ld.ech.ch/schema/0292/meta-common/IsProcessStep> a owl:Class ;
    rdfs:label "IsProcessStep" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ] ;
    skos:definition """A mixin class for a single step in a multi-stage process (e.g.,
a deliberation step of an affair or a phase step of a consultation).
Combines identification and event-duration slots and adds a free-text
remark slot. Concrete step classes add their own type-specific slots.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Eine Mixin-Klasse für einen einzelnen Schritt in einem
mehrstufigen Prozess (z. B. Bearbeitungsschritt eines Geschäfts oder
Phasen­schritt einer Konsultation). Kombiniert Identifikations- und
Zeitdauer-Slots und ergänzt einen freien Bemerkungs-Slot. Konkrete
Step-Klassen ergänzen ihre eigenen typ-spezifischen Slots.
""" .

<https://ld.ech.ch/schema/0292/meta-common/multilingualValue> a owl:ObjectProperty ;
    rdfs:label "multilingual_value" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:definition """A multilingual value with language specification.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Ein mehrsprachiger Wert mit Angabe der Sprache.
""" .

<https://ld.ech.ch/schema/0294/actors.owl.ttl> a owl:Ontology ;
    rdfs:label "actors-schema" ;
    dcterms:license "CC-BY" ;
    dcterms:title "Actors Schema" ;
    skos:definition """A schema describing political actors including persons, groups, memberships, and interest links.
""" ;
    act:description_de """Ein Schema zur Beschreibung politischer Akteure einschliesslich Personen, Gruppen, Mitgliedschaften und Interessenbindungen.
""" .

act:Container a owl:Class ;
    rdfs:label "Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom act:Group ;
            owl:onProperty act:group ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:interestLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Membership ;
            owl:onProperty act:membership ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:InterestLink ;
            owl:onProperty act:interestLink ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Person ;
            owl:onProperty act:person ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:person ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:membership ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:group ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """Container for political actors, groups, and relationships.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Container für politische Akteure, Gruppen und Beziehungen.
""" .

act:role_label a owl:DatatypeProperty ;
    rdfs:label "role_label" ;
    skos:definition """Descriptive label for the role when 'other' is selected in the RoleEnum.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Beschreibende Bezeichnung für die Rolle, wenn 'other' im RoleEnum ausgewählt ist.
""" .

<https://ld.ech.ch/schema/0292/meta-common/GroupReference> a owl:Class ;
    rdfs:label "GroupReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/abbreviation> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/abbreviation> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """Lightweight reference to a group with key identification data at time of linking.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    act:description_de """Leichtgewichtige Referenz auf eine Gruppe mit den wichtigsten Identifikationsmerkmalen zum Zeitpunkt der Verknüpfung.
""" .

<https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#businessAddress> a owl:Class ;
    rdfs:label "businessAddress" ;
    rdfs:subClassOf act:AddressTypeEnum ;
    skos:definition """Business address.
""" ;
    act:description_de """Geschäftsadresse.
""" .

<https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#localAddress> a owl:Class ;
    rdfs:label "localAddress" ;
    rdfs:subClassOf act:AddressTypeEnum ;
    skos:definition """Local address.
""" ;
    act:description_de """Lokaladresse.
""" .

<https://ld.ech.ch/schema/0294/actors/AddressTypeEnum#privateAddress> a owl:Class ;
    rdfs:label "privateAddress" ;
    rdfs:subClassOf act:AddressTypeEnum ;
    skos:definition """Private address.
""" ;
    act:description_de """Privatadresse.
""" .

act:Citizenship a owl:Class ;
    rdfs:label "Citizenship" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[A-Z]{2}$" ] ) ] ;
            owl:onProperty act:country ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:country ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:country ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """Citizenship (also used for Nationality) of a person indicating the country and temporal validity. If there is no `valid_from` provided, the information is not known. If it is known that the citizenship is valid from birth, the birthdate is to be repeated here. If there is no `valid_through`, the citizenship is still active.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Staatsangehörigkeit (wird auch für Nationalität verwendet) einer Person unter Angabe des Landes und der zeitlichen Gültigkeit. Wenn kein `valid_from` angegeben ist, ist diese Information nicht bekannt. Ist bekannt, dass die Staatsangehörigkeit seit der Geburt gültig ist, ist das Geburtsdatum hier anzugeben. Wenn kein `valid_through` angegeben ist, ist die Staatsangehörigkeit weiterhin gültig.
""" .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#contact_website> a owl:Class ;
    rdfs:label "contact_website" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """Contact website.
""" ;
    act:description_de """Kontakt-Website.
""" .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#email> a owl:Class ;
    rdfs:label "email" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """Email address.
""" ;
    act:description_de """E-Mail-Adresse.
""" .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#linked_in> a owl:Class ;
    rdfs:label "linked_in" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """LinkedIn profile.
""" ;
    act:description_de """LinkedIn-Profil.
""" .

<https://ld.ech.ch/schema/0294/actors/ContactTypeEnum#twitter> a owl:Class ;
    rdfs:label "twitter" ;
    rdfs:subClassOf act:ContactTypeEnum ;
    skos:definition """Twitter profile.
""" ;
    act:description_de """Twitter-Profil.
""" .

act:ElectoralDistrict a owl:Class ;
    rdfs:label "ElectoralDistrict" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:district ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:district ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:district ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """Electoral district or region where a person is politically active; with temporal validity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Wahlkreis oder Wahlregion, in der eine Person politisch aktiv ist; mit zeitlicher Gültigkeit.
""" .

act:Gender a owl:Class ;
    rdfs:label "Gender" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:pronouns ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:GenderCodeEnum ;
            owl:onProperty act:genderCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:pronouns ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:genderCode ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:genderCode ],
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """Gender of a person indicating a gender code and temporal validity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Geschlecht einer Person mit Angabe eines Geschlechtscodes und der zeitlichen Gültigkeit.
""" .

<https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#diverse> a owl:Class ;
    rdfs:label "diverse" ;
    rdfs:subClassOf act:GenderCodeEnum ;
    skos:definition "Diverse / non-binary." ;
    act:description_de "Divers / nicht-binär." .

<https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#female> a owl:Class ;
    rdfs:label "female" ;
    rdfs:subClassOf act:GenderCodeEnum ;
    skos:definition "Female." ;
    act:description_de "Weiblich." .

<https://ld.ech.ch/schema/0294/actors/GenderCodeEnum#male> a owl:Class ;
    rdfs:label "male" ;
    rdfs:subClassOf act:GenderCodeEnum ;
    skos:definition "Male." ;
    act:description_de "Männlich." .

act:Group a owl:Class ;
    rdfs:label "Group" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:partyColor ],
        [ a owl:Restriction ;
