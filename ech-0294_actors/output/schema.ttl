""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """UID der Organisation (Format eCH-0097: CHE-XXX.XXX.XXX) aus dem eidgenössischen UID-Register (uid.admin.ch).
""" .

act:personReference a owl:ObjectProperty ;
