""" .

act:gender a owl:ObjectProperty ;
    rdfs:label "genders" ;
    rdfs:range act:Gender ;
    skos:definition """Gender of the person.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Geschlecht der Person.
""" .

act:group a owl:ObjectProperty ;
    rdfs:label "groups" ;
    rdfs:range act:Group ;
    skos:definition """Collection of groups.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Sammlung von Gruppen.
""" .

act:languageProficiency a owl:ObjectProperty ;
    rdfs:label "language_proficiencies" ;
    rdfs:range act:LanguageProficiency ;
    skos:definition """Language proficiencies of the person.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Sprachkompetenzen der Person.
""" .

act:membership a owl:ObjectProperty ;
    rdfs:label "memberships" ;
    rdfs:range act:Membership ;
    skos:definition """Collection of memberships.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Sammlung von Mitgliedschaften.
""" .

act:name a owl:ObjectProperty ;
    rdfs:label "names" ;
    rdfs:range act:Name ;
    skos:definition """Names of the person with type and value.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Namen der Person mit Typ und Wert.
""" .

act:occupation a owl:ObjectProperty ;
    rdfs:label "occupations" ;
    rdfs:range act:Occupation ;
    skos:definition """Occupations or professions of the person.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Berufe oder Tätigkeiten der Person.
""" .

act:parentGroup a owl:DatatypeProperty ;
    rdfs:label "parent_groups" ;
    rdfs:range xsd:anyURI ;
    skos:definition """Link to parent groups. For example, the parent party for cantonal parties, or to describe the hierarchy in the executive. Also used to link sub-commissions to commissions, or factions to both their parliament and their party. (parentGroup is typically used within the same group_type, but cross-type links are permitted, e.g., faction → parliament and faction → party.)
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Übergeordnete Gruppe. Zum Beispiel die Mutterpartei zu Kantonalparteien, oder zur Beschreibung der Hierarchie in der Exekutive. Auch zur Verknüpfung von Subkommissionen mit Kommissionen oder Fraktionen mit Parlament und Partei. (parentGroup wird typischerweise im selben group_type verwendet, typenübergreifende Verknüpfungen sind aber erlaubt, z.B. Fraktion → Parlament und Fraktion → Partei.)
""" .

act:person a owl:ObjectProperty ;
    rdfs:label "persons" ;
    rdfs:range act:Person ;
    skos:definition """Collection of persons.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Sammlung von Personen.
""" .

act:pronouns a owl:DatatypeProperty ;
    rdfs:label "pronouns" ;
    skos:definition """Pronouns used by the person.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Von der Person verwendete Pronomen.
""" .

act:training a owl:ObjectProperty ;
    rdfs:label "trainings" ;
    rdfs:range act:Training ;
    skos:definition """Trainings or educations of the person. Guideline: generally only provide the highest qualification obtained.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> ;
    act:description_de """Ausbildungen oder Bildungen der Person. Richtlinie: Im Grundsatz nur die höchste Ausbildung angeben.
""" .

