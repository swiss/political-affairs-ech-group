    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/dateModified> a owl:DatatypeProperty ;
    rdfs:label "date_modified" ;
    rdfs:range xsd:date ;
    skos:definition """[de] Das Datum, an dem eine Entität zuletzt geändert wurde.
[en] The date when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datePlanned> a owl:DatatypeProperty ;
    rdfs:label "date_planned" ;
    rdfs:range xsd:date ;
    skos:definition """[de] Das geplante Datum eines instantanen Ereignisses oder Vorkommens (ohne Zeitdauer).
[en] The planned date of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimeActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das tatsächliche Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommens (ohne Zeitdauer).
[en] The actual date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_begin_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das tatsächliche Startdatum und die Uhrzeit eines Ereignisses oder Vorkommens mit Zeitdauer.
[en] The actual start date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_begin_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das geplante Startdatum und die Uhrzeit eines Ereignisses oder Vorkommens mit Zeitdauer.
[en] The planned start date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> a owl:DatatypeProperty ;
    rdfs:label "datetime_created" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das Datum und die Uhrzeit, an dem eine Entität erstellt wurde.
[en] The date and time when an entity was created.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_end_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das tatsächliche Enddatum und die Uhrzeit eines Ereignisses oder Vorkommens mit Zeitdauer.
[en] The actual end date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_end_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das geplante Enddatum und die Uhrzeit eines Ereignisses oder Vorkommens mit Zeitdauer.
[en] The planned end date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimeModified> a owl:DatatypeProperty ;
    rdfs:label "datetime_modified" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das Datum und die Uhrzeit, an dem eine Entität zuletzt geändert wurde.
[en] The date and time when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[de] Das geplante Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommens (ohne Zeitdauer).
[en] The planned date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/globalURI> a owl:DatatypeProperty ;
    rdfs:label "global_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """[de] Eine eindeutige, global gültige URI für die Entität.
[en] A unique, globally valid URI for the entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/isCurrent> a owl:DatatypeProperty ;
    rdfs:label "is_active" ;
    rdfs:range xsd:boolean ;
    skos:definition """[de] Gibt an, ob die Information aktuell gültig ist. Kann nützlich sein, wenn diese Information explizit vorhanden ist.
[en] Indicates whether the information is currently valid. Can be useful when this information is explicitly available.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/labelLong> a owl:DatatypeProperty ;
    rdfs:label "label_long" ;
    skos:definition """[de] Möglichkeit bei einer strukturierten Information, ein erweitertesLabel zu vergeben (bspw. Anzeigename mit Titel, Anstellung, etc.).
[en] Option to assign an extended label to a structured piece of information (e.g., display name with title, position, etc.).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/localId> a owl:DatatypeProperty ;
    rdfs:label "local_id" ;
    skos:definition """[de] Lokaler Identifikator. Bspw. eine UUID aus dem Ratsinformationssystem.
[en] Local identifier. For example, a UUID from the council information system.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

<https://ld.ech.ch/schema/0292/meta-common/wikidataUri> a owl:DatatypeProperty ;
    rdfs:label "wikidata_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """[de] Eine URI, die auf eine Wikidata-Entität verweist, z.B. https://www.wikidata.org/wiki/Q39 für die Schweiz.
[en] A URI that refers to a Wikidata entity, e.g. https://www.wikidata.org/wiki/Q39 for Switzerland.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> .

act:Address a owl:Class ;
    rdfs:label "Address" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty act:postalCode ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:streetAddress ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:postalLocality ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:addressURI ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty act:addressURI ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:postalCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:streetAddress ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:addressType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:addressType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:postalLocality ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:AddressTypeEnum ;
            owl:onProperty act:addressType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:postalLocality ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:streetAddress ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:addressURI ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:postalCode ] ;
    skos:definition """[de] Eine Adresse mit einem Typ (z.B. Privatadresse, Geschäftsadresse) und einem Wert.
[en] An address with a type (e.g., private address, business address) and a value.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:Contact a owl:Class ;
    rdfs:label "Contact" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:contactType ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:ContactTypeEnum ;
            owl:onProperty act:contactType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:contactType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ] ;
    skos:definition """[de] Kontaktinformation einer Person mit Angabe eines Typs (z.B. E-Mail, LinkedIn) und eines Werts.
[en] Contact information of a person indicating a type (e.g., email, LinkedIn) and a value.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:InterestLink a owl:Class ;
    rdfs:label "InterestLink" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:organizationUid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:committee ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:organizationAddress ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:committee ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:functionRole ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:legalForm ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:organizationLabel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:organizationLabel ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty act:isPaid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty act:interestType ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:Person ;
            owl:onProperty act:concernedPerson ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:legalForm ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:organizationLabel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:functionRole ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:functionRole ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:organizationAddress ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:interestType ],
        [ a owl:Restriction ;
            owl:allValuesFrom act:InterestTypeEnum ;
            owl:onProperty act:interestType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:organizationUid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:legalForm ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:organizationUid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:committee ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty act:concernedPerson ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty act:organizationAddress ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:concernedPerson ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty act:isPaid ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification>,
        <https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> ;
    skos:definition """[de] Eine Interessenbindung (Interessenkonflikt, Politikfinanzierung) einer Person zu einer Organisation.
[en] An interest link (conflict of interest, political financing) of a person to an organization.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:addressType a owl:ObjectProperty ;
    rdfs:label "address_type" ;
    rdfs:range act:AddressTypeEnum ;
    skos:definition """[de] Typ der Adresse.
[en] Type of address.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:addressURI a owl:DatatypeProperty ;
    rdfs:label "address_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """[de] URI der Adresse.
[en] URI of the address.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:authorizedToVote a owl:DatatypeProperty ;
    rdfs:label "authorized_to_vote" ;
    rdfs:range xsd:boolean ;
    skos:definition """[de] Gibt an, ob die Person stimmberechtigt ist.
[en] Indicates if the person is authorized to vote.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:birthYear a owl:DatatypeProperty ;
    rdfs:label "birth_year" ;
    rdfs:range xsd:integer ;
    skos:definition """[de] Geburtsjahr.
[en] Year of birth.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:committee a owl:DatatypeProperty ;
    rdfs:label "committee" ;
    skos:definition """[en] Committee or board (e.g., foundation board, board of directors).
[de] Gremium (z.B. Stiftungsrat, Verwaltungsrat).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:concernedGroup a owl:ObjectProperty ;
    rdfs:label "concerned_group" ;
    rdfs:range act:Group ;
    skos:definition """[de] Link zu einer Gruppe, auf die sich die Zugehörigkeit bezieht.
[en] Link to a group that the affiliation concerns.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:contactType a owl:ObjectProperty ;
    rdfs:label "contact_type" ;
    rdfs:range act:ContactTypeEnum ;
    skos:definition """[de] Typ der Kontaktinformation.
[en] Type of contact information.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:country a owl:DatatypeProperty ;
    rdfs:label "country" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[A-Z]{2}$" ] ) ] ;
    skos:definition """[de] ISO 3166 Ländercode.
[en] ISO 3166 country code.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:deathYear a owl:DatatypeProperty ;
    rdfs:label "death_year" ;
    rdfs:range xsd:integer ;
    skos:definition """[de] Todesjahr.
[en] Year of death.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:district a owl:DatatypeProperty ;
    rdfs:label "district" ;
    skos:definition """[de] Wahlkreis oder Wahlregion.
[en] Electoral district or region.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:electoralDistrict a owl:ObjectProperty ;
    rdfs:label "electoral_district" ;
    rdfs:range act:ElectoralDistrict ;
    skos:definition """[de] Link zum Wahlbezirk.
[en] Link to the electoral district.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:enterprise a owl:DatatypeProperty ;
    rdfs:label "enterprise" ;
    skos:definition """[de] Name des Unternehmens.
[en] Name of the enterprise.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:enterpriseUid a owl:DatatypeProperty ;
    rdfs:label "enterprise_uid" ;
    skos:definition """[de] UID des Unternehmens.
[en] UID of the enterprise.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:functionRole a owl:DatatypeProperty ;
    rdfs:label "function_role" ;
    skos:definition """[en] Function or role in the organization.
[de] Funktion oder Rolle in der Organisation.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:genderCode a owl:DatatypeProperty ;
    rdfs:label "gender_code" ;
    skos:definition """[de] Geschlechtscode (z.B. gemäß ISO 5218).
[en] Gender code (e.g., according to ISO 5218).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:groupType a owl:ObjectProperty ;
    rdfs:label "group_type" ;
    rdfs:range act:GroupType ;
    skos:definition """[de] Link zum Gruppentyp.
[en] Link to the group type.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:groupTypeEnum a owl:ObjectProperty ;
    rdfs:label "group_type_enum" ;
    rdfs:range act:GroupTypeEnum ;
    skos:definition """[de] Link zum kontrollierten Vokabular für Gruppentypen.
[en] Link to the controlled vocabulary for group types.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:interestType a owl:ObjectProperty ;
    rdfs:label "interest_type" ;
    rdfs:range act:InterestTypeEnum ;
    skos:definition """[de] Art der Interessenbindung (Berufliche Tätigkeit, Politische Ämter, Verein).
[en] Type of interest link (professional activity, political office, association).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:isCorrespondence a owl:DatatypeProperty ;
    rdfs:label "is_correspondence" ;
    rdfs:range xsd:boolean ;
    skos:definition """[de] Gibt an, ob es sich um die bevorzugte Sprache handelt.
[en] Indicates if this is the preferred language.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:isNative a owl:DatatypeProperty ;
    rdfs:label "is_native" ;
    rdfs:range xsd:boolean ;
    skos:definition """[de] Gibt an, ob es sich um die Muttersprache handelt.
[en] Indicates if this is the native language.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:landingPage a owl:DatatypeProperty ;
    rdfs:label "landing_page" ;
    skos:definition """[de] URL mit weiteren Informationen.
[en] URL providing further information.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:legalForm a owl:DatatypeProperty ;
    rdfs:label "legal_form" ;
    skos:definition """[en] Legal form of the organization.
[de] Rechtsform der Organisation.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:nameType a owl:ObjectProperty ;
    rdfs:label "name_type" ;
    rdfs:range act:NameTypeEnum ;
    skos:definition """[de] Typ des Namens.
[en] Type of name.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:occupationCode a owl:DatatypeProperty ;
    rdfs:label "occupation_code" ;
    skos:definition """[de] ISCO-19 Code der Tätigkeit.
[en] ISCO-19 code of the occupation.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:organizationAddress a owl:DatatypeProperty ;
    rdfs:label "organization_address" ;
    skos:definition """[en] Address of the organization.
[de] Adresse der Organisation.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:organizationLabel a owl:DatatypeProperty ;
    rdfs:label "organization_label" ;
    skos:definition """[en] Label of the organization.
[de] Bezeichnung der Organisation.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:organizationUid a owl:DatatypeProperty ;
    rdfs:label "organization_uid" ;
    skos:definition """[en] UID of the organization (for analysis with NOGA codes, etc.).
[de] UID der Organisation (für Auswertungen mit NOGA-Codes, etc.).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:partyColor a owl:DatatypeProperty ;
    rdfs:label "party_color" ;
    skos:definition """[de] Parteifarbe (optional für Parteien).
[en] Party color (optional for parties).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:picture a owl:DatatypeProperty ;
    rdfs:label "picture" ;
    skos:definition """[de] Link zu einem Bild (bevorzugt: PNG, dann JPG, dann GIF).
[en] Link to an image (preferred: PNG, then JPG, then GIF).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:postalCode a owl:DatatypeProperty ;
    rdfs:label "postal_code" ;
    rdfs:range xsd:integer ;
    skos:definition """[de] Postleitzahl.
[en] Postal code.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:postalLocality a owl:DatatypeProperty ;
    rdfs:label "postal_locality" ;
    skos:definition """[de] Ort.
[en] Locality.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:roleType a owl:ObjectProperty ;
    rdfs:label "role_type" ;
    rdfs:range act:RoleType ;
    skos:definition """[en] Role of the person in the membership or function.
[de] Rolle der Person in der Mitgliedschaft oder Funktion.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:roleTypeEnum a owl:ObjectProperty ;
    rdfs:label "role_type_enum" ;
    rdfs:range act:RoleEnum ;
    skos:definition """[en] Role of the person in the membership or function.
[de] Rolle der Person in der Mitgliedschaft oder Funktion.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:spatial a owl:DatatypeProperty ;
    rdfs:label "spatial" ;
    skos:definition """[de] Räumliche Referenz (Gemeindenummer, Kantonsnummer, z.B. ld.admin.ch/municipality/234).
[en] Spatial reference (municipality number, canton number, e.g., ld.admin.ch/municipality/234).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:statutesURL a owl:DatatypeProperty ;
    rdfs:label "statutes_url" ;
    skos:definition """[de] URL zu Parteistatuten (optional für Parteien).
[en] URL to party statutes (optional for parties).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:streetAddress a owl:DatatypeProperty ;
    rdfs:label "street_address" ;
    skos:definition """[de] Strassenadresse.
[en] Street address.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:trainingCode a owl:DatatypeProperty ;
    rdfs:label "training_code" ;
    skos:definition """[de] ISCO-19 Code der Ausbildung oder Bildung.
[en] ISCO-19 code of the training or education.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0294/actors> .

act:trainingType a owl:ObjectProperty ;
    rdfs:label "training_type" ;
    rdfs:range act:TrainingTypeEnum ;
    skos:definition """[de] Typ der Ausbildung oder Bildung.
[en] Type of training or education.
""" ;
