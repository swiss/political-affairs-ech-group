@prefix act: <https://ld.ech.ch/schema/0294/actors/> .
@prefix mcm: <https://ld.ech.ch/schema/0292/meta-common/> .
@prefix schema1: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

act:swiss_politicians_example a act:Container ;
    act:person <https://www.wikidata.org/wiki/Q813067> .

<https://www.wikidata.org/wiki/Q813067> a act:Person ;
    schema1:birthDate "1964-07-12"^^xsd:date ;
    mcm:label "Beat Jans" ;
    mcm:labelLong "Beat Jans, dipl. nat. ETH" ;
    act:address [ a act:Address ;
            act:addressType "businessAddress" ;
            act:postalLocality "Basel-Stadt" ] ;
    act:birthYear 1964 ;
    act:citizenship [ a act:Citizenship ;
            schema1:validFrom "1964-07-12"^^xsd:date ;
            act:country "CH" ] ;
    act:contact [ a act:Contact ;
            mcm:value "http://www.beat-jans.ch" ;
            act:contactType "contact_website" ],
        [ a act:Contact ;
            mcm:value "beat.jans@admin.ch" ;
            act:contactType "email" ] ;
    act:electoralDistrict [ a act:ElectoralDistrict ;
            schema1:validFrom "2010-01-01"^^xsd:date ;
            act:district "Basel-Stadt" ] ;
    act:gender [ a act:Gender ;
            schema1:validFrom "1964-07-12"^^xsd:date ;
            act:genderCode "male" ;
            act:pronouns "er",
                "ihm" ] ;
    act:languageProficiency [ a act:LanguageProficiency ;
            mcm:language "de" ;
            act:isCorrespondence true ;
            act:isNative true ] ;
    act:name [ a act:Name ;
            mcm:value "Beat" ;
            act:nameType <https://ld.ech.ch/schema/0294/actors/vocabulary/NameTypeEnum/PersonFirstName> ],
        [ a act:Name ;
            schema1:validFrom "1964-07-12"^^xsd:date ;
            mcm:value "Jans" ;
            act:nameType <https://ld.ech.ch/schema/0294/actors/vocabulary/NameTypeEnum/PersonOfficialName> ] ;
    act:occupation [ a act:Occupation ;
            schema1:validFrom "1964-01-01"^^xsd:date ;
            mcm:isCurrent true ;
            mcm:label "Politiker" ] ;
    act:picture "https://commons.wikimedia.org/wiki/File:Beat_Jans_(2026)_(cropped).jpg"^^xsd:anyURI ;
    act:training [ a act:Training ;
            mcm:value "dipl. nat. ETH" ;
            act:trainingType "uni" ] .


