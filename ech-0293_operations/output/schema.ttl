            owl:allValuesFrom xsd:integer ;
            owl:onProperty ops:agenda_item_position ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:parent_agenda_item ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:state_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:leading_actor_id ],
        [ a owl:Restriction ;
