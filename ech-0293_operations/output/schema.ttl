<https://ch.paf.link/schema/meta/vocabulary/date_types/LastRevision> a owl:Class ;
    rdfs:label "last_revision" ;
    rdfs:subClassOf ops:DateTypesEnum .

<https://ch.paf.link/schema/meta/vocabulary/document_category/GroupDocuments> a owl:Class ;
    rdfs:label "group_documents" ;
    dcterms:title "Group documents" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Unterlagen, die zu einer Gruppe (Kommission, Partei, Delegation etc.) gehören. Beispiele: Statuten, Einsetzungsverfügungen, Kommissionszuweisungen, Jahresberichte, Berichte zu internationalen Aktivitäten.
[en] Documents belonging to a group (committee, party, delegation, etc.). Examples: statutes, establishment decrees, committee allocations, annual reports, reports on international activities.
""" ;
    ops:label_de "Gruppenunterlagen" ;
    ops:label_en "Group documents" ;
    ops:label_fr "Documents de groupe" ;
    ops:label_it "Documenti di gruppo" ;
    ops:label_rm "Documents da gruppa" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/InterestDisclosure> a owl:Class ;
    rdfs:label "interest_disclosure" ;
    dcterms:title "Interest disclosure" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Register der Interessenbindungen von Ratsmitgliedern. Beispiele: Register der Interessenbindungen Nationalrat, Register der Interessenbindungen Ständerat.
[en] Registers of interest disclosures of council members. Examples: register of interest disclosures National Council, register of interest disclosures Council of States.
""" ;
    ops:label_de "Interessenbindungen" ;
    ops:label_en "Interest disclosures" ;
    ops:label_fr "Liens d'intérêts" ;
    ops:label_it "Relazioni d'interesse" ;
    ops:label_rm "Colliaziuns d'interess" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/MediaRelease> a owl:Class ;
    rdfs:label "media_release" ;
    dcterms:title "Media release" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Medienmitteilungen.
[en] Press releases.
""" ;
    ops:label_de "Medienmitteilung" ;
    ops:label_en "Media release" ;
    ops:label_fr "Communiqué de presse" ;
    ops:label_it "Comunicato stampa" ;
    ops:label_rm "Communicaziun da medias" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/MeetingDocuments> a owl:Class ;
    rdfs:label "meeting_documents" ;
    dcterms:title "Meeting documents" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Sitzungsunterlagen, die zu Beginn einer Sitzung zu den Geschäften vorliegen. Beispiele: Traktandenliste, Tagesordnung, Sessionsprogramm, Sessionsvorschau, traktandierte Petitionen, Vorstossliste, Vereidigung/Gelübdenahme, Tagblattbeilagen, Geschäftsverzeichnis, Vorschau, Traktandenvorschau, Vorstoss Dringlichkeit.
[en] Meeting documents available at the start of a meeting concerning the affairs. Examples: agenda list, daily agenda, session programme, session preview, agendaed petitions, motion list, oath ceremony, daily journal supplements, affairs directory.
""" ;
    ops:label_de "Sitzungsunterlagen" ;
    ops:label_en "Meeting documents" ;
    ops:label_fr "Documents de séance" ;
    ops:label_it "Documenti di seduta" ;
    ops:label_rm "Documents da sesida" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/MeetingPlanning> a owl:Class ;
    rdfs:label "meeting_planning" ;
    dcterms:title "Meeting planning" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Planungsdokumente für Sitzungen und Sessionen. Beispiele: Einladung, Sitzplan, Arbeitsplanung, Zeitbudget, Geschäftsplanung, Freitagsliste, Fristen für Einzelanträge, Liste der Zutrittsberechtigten, Veranstaltungen während der Session.
[en] Planning documents for meetings and sessions. Examples: invitation, seating plan, work schedule, time budget, affairs planning, friday list, amendment deadlines, access authorization list, session events.
""" ;
    ops:label_de "Sitzungsplanung" ;
    ops:label_en "Meeting planning" ;
    ops:label_fr "Planification de séance" ;
    ops:label_it "Pianificazione della seduta" ;
    ops:label_rm "Planisaziun da sesida" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/MemberDirectory> a owl:Class ;
    rdfs:label "member_directory" ;
    dcterms:title "Member directory" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Mitgliederverzeichnisse. Beispiele: Mitglieder der eidgenössischen Räte, Mitgliederverzeichnisse von Kommissionen, Gruppen und Freundschaftsgruppen, Liste aller Bundesrätinnen und Bundesräte.
[en] Member directories. Examples: members of the federal councils, member directories of committees, groups and friendship groups, list of all Federal Councillors.
""" ;
    ops:label_de "Mitgliederverzeichnis" ;
    ops:label_en "Member directory" ;
    ops:label_fr "Liste des membres" ;
    ops:label_it "Elenco dei membri" ;
    ops:label_rm "Glista dals commembers" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/Other> a owl:Class ;
    rdfs:label "other" ;
    dcterms:title "Other" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Dokumenttyp, der keiner der definierten Kategorien zugeordnet werden kann oder bei dem die Kategorie nicht bekannt ist. Default-Wert wenn `document_category` nicht explizit gesetzt wird.
[en] Document type that cannot be assigned to any of the defined categories or where the category is unknown. Default value if `document_category` is not set explicitly.
""" ;
    ops:label_de "Andere" ;
    ops:label_en "Other" ;
    ops:label_fr "Autre" ;
    ops:label_it "Altro" ;
    ops:label_rm "Auter" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/PersonDocuments> a owl:Class ;
    rdfs:label "person_documents" ;
    dcterms:title "Person documents" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Personenbezogene Unterlagen. Beispiele: Portraits der Ratsmitglieder, Fotos, Listen der persönlichen Mitarbeitenden.
[en] Person-related documents. Examples: portraits of council members, photos, lists of personal staff.
""" ;
    ops:label_de "Personenunterlagen" ;
    ops:label_en "Person documents" ;
    ops:label_fr "Documents personnels" ;
    ops:label_it "Documenti personali" ;
    ops:label_rm "Documents da persuna" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/Protocol> a owl:Class ;
    rdfs:label "protocol" ;
    dcterms:title "Protocol" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Protokolle aller Art. Beispiele: Entscheidungsprotokoll, Wortprotokoll, Kurzprotokoll, Tagblatt, Wortlautdokument, Eröffnungsrede, Sprecherliste, Audio- und Videoaufnahmen.
[en] Protocols of any kind. Examples: decision protocol, verbatim protocol, short protocol, daily journal (Tagblatt), opening speech, speaker list, audio and video recordings.
""" ;
    ops:label_de "Protokoll" ;
    ops:label_en "Minutes" ;
    ops:label_fr "Procès-verbal" ;
    ops:label_it "Verbale" ;
    ops:label_rm "Protocol" .

<https://ch.paf.link/schema/meta/vocabulary/document_category/VotingResult> a owl:Class ;
    rdfs:label "voting_result" ;
    dcterms:title "Voting result" ;
    rdfs:subClassOf ops:DocumentCategoryEnum ;
    skos:definition """[de] Abstimmungs- und Wahlergebnisse. Beispiele: Abstimmungsprotokoll, Wahlprotokoll, Protokolle namentlicher Abstimmungen.
[en] Voting and election results. Examples: voting protocol, election protocol, roll-call voting protocols.
""" ;
    ops:label_de "Abstimmungsergebnis" ;
    ops:label_en "Voting result" ;
    ops:label_fr "Résultat du vote" ;
    ops:label_it "Risultato della votazione" ;
    ops:label_rm "Resultat da votaziun" .

