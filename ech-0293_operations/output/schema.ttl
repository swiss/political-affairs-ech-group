ops:StateEnum a owl:Class ;
    rdfs:label "StateEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/state/planned> <https://ch.paf.link/schema/operations/enum/state/canceled> <https://ch.paf.link/schema/operations/enum/state/postponed> ) ;
