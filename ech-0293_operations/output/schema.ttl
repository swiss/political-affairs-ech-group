            owl:onProperty ops:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:protocolRef ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:actor_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:state ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:StateEnum ;
            owl:onProperty ops:state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:sequential_number ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:parent_legislature ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:group_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:MultilingualString ;
            owl:onProperty ops:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:body_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:actor_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:body_key ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:body_key ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:protocolRef ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:state ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:group_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:number ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:location ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:meeting_abbreviation ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/GroupReference> ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:meetingType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:administrative_id ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification>,
        <https://ld.ech.ch/schema/0292/meta-common/IsEventWithDuration> ;
    skos:definition """[en] A general meeting class used for Sessions, Comittee Meetings, individual session Sittings and other various Meetings.
[de] Eine allgemeine Sitzungsklasse, die für Sessionen, Kommissionssitzungen, Sessionssitzung und andere verschiedene Versammlungen verwendet wird.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:Speech a owl:Class ;
    rdfs:label "Speech" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:media_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:role ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:text_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:media_format ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:text_format ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:datetime_begin ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:actor_fullname ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:text_format ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:media_url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:role ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:start ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:actor_fullname ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/PersonReference> ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:datetime_end ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:media_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:text_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:text_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty ops:datetime_end ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:datetime_end ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:start ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:text_format ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:actor_fullname ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:media_url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:media_format ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:start ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:media_format ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:media_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty ops:datetime_begin ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:role ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:datetime_begin ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:media_url ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """[en] A speech or statement made during a meeting (also called Votum or speaker segment).
[de] Eine Wortmeldung während einer Sitzung (auch Votum oder Redebeitrag genannt).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:actor_fullname a owl:DatatypeProperty ;
    rdfs:label "actor_fullname" ;
    skos:definition "Full name of the actor/person" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:actor_name a owl:DatatypeProperty ;
    rdfs:label "actor_name" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Name of the political body (e.g., Nationalrat).
[de] Name des politischen Organs (z.B. Nationalrat).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:agenda_item_category a owl:DatatypeProperty ;
    rdfs:label "agenda_item_category" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Category for grouped agenda items (e.g., introduction, by department, technical agenda items).
[de] Kategorie für gruppierte Traktanden (z.B. Einführung, nach Departement, technische Traktanden).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:agenda_item_number a owl:DatatypeProperty ;
    rdfs:label "agenda_item_number" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Sequential number of the agenda item (string type to support roman numerals).
[de] Laufnummer des Traktandums (String-Typ zur Unterstützung römischer Ziffern).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:agenda_item_position a owl:DatatypeProperty ;
    rdfs:label "agenda_item_position" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Integer position of the agenda item in the meeting sequence.
[de] Ganzzahlige Position des Traktandums in der Sitzungsreihenfolge.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:agenda_item_type a owl:ObjectProperty ;
    rdfs:label "agenda_item_type" ;
    rdfs:range ops:AgendaItemTypeEnum ;
    skos:definition """[en] Type of agenda item, distinguishing individual items from groups.
[de] Art des Traktandums, unterscheidet Einzeltraktanden von Traktandengruppen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:attendance_type a owl:ObjectProperty ;
    rdfs:label "attendance_type" ;
    rdfs:range ops:AttendanceTypeEnum ;
    skos:definition "Type of individual attendance" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:count a owl:DatatypeProperty ;
    rdfs:label "count" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] The count of votes for the total other category.
[de] Die Anzahl der Stimmen für die Kategorie "Andere".
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:election_type a owl:ObjectProperty ;
    rdfs:label "election_type" ;
    rdfs:range ops:ElectionTypeEnum ;
    skos:definition "Type of election procedure" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:group_id a owl:ObjectProperty ;
    rdfs:label "group_id" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/GroupReference> ;
    skos:definition """[en] Reference to the group or body (lightweight snapshot at time of linking).
[de] Referenz auf die Gruppe oder das Gremium (leichtgewichtiger Snapshot zum Zeitpunkt der Verknüpfung).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:group_name a owl:DatatypeProperty ;
    rdfs:label "group_name" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the group or body" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:has_resolution a owl:ObjectProperty ;
    rdfs:label "has_resolution" ;
    rdfs:range ops:Resolution ;
    skos:definition """[en] The resolutionor decision taken on this agenda item.
[de] Die Resolution oder Entscheidung zu diesem Traktandum.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:individual_vote_type a owl:ObjectProperty ;
    rdfs:label "individual_vote_type" ;
    rdfs:range ops:IndividualVoteTypeEnum ;
    skos:definition """[en] Type of vote cast (yes, no, abstention, no vote, etc.).
[de] Art der abgegebenen Stimme (Ja, Nein, Enthaltung, nicht abgestimmt, etc.).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:label_abstention a owl:DatatypeProperty ;
    rdfs:label "label_abstention" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Meaning of an 'abstention' vote.
[de] Bedeutung einer Enthaltungsstimme.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:label_no a owl:DatatypeProperty ;
    rdfs:label "label_no" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Meaning of a 'no' vote.
[de] Bedeutung einer 'Nein'-Stimme.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:label_yes a owl:DatatypeProperty ;
    rdfs:label "label_yes" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Meaning of a 'yes' vote.
[de] Bedeutung einer 'Ja'-Stimme.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:leading_actor_id a owl:DatatypeProperty ;
    rdfs:label "leading_actor_id" ;
    rdfs:range xsd:string ;
    skos:definition """[en] The leading department for the agenda item.
[de] Das federführende Departement für den Tagesordnungspunkt.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:location a owl:DatatypeProperty ;
    rdfs:label "location" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:media_format a owl:DatatypeProperty ;
    rdfs:label "media_format" ;
    skos:definition "MIME type of the media file" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:media_url a owl:DatatypeProperty ;
    rdfs:label "media_url" ;
    skos:definition "URL to media file (audio/video)" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:meetingType a owl:ObjectProperty ;
    rdfs:label "meeting_type" ;
    rdfs:range ops:MeetingTypeEnum ;
    skos:definition "Type of the meeting, e.g. session, committee, sitting, various" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:optional a owl:DatatypeProperty ;
    rdfs:label "optional" ;
    rdfs:range xsd:boolean ;
    skos:definition """[en] Indicates if the meeting or voting is optional.
[de] Gibt an, ob die Sitzung oder Abstimmung optional ist.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:parentAttendance a owl:ObjectProperty ;
    rdfs:label "parent_attendance" ;
    rdfs:range ops:Attendance ;
    skos:definition """[en] The Attendance aggregate this individual attendance record belongs to.
[de] Das Attendance-Aggregat, zu dem dieser einzelne Anwesenheits-Eintrag gehört.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:parentVoting a owl:ObjectProperty ;
    rdfs:label "parent_voting" ;
    rdfs:range ops:Voting ;
    skos:definition """[en] The ID of the voting associated with the individual vote.
[de] Die ID der Abstimmung, die mit der Einzelstimme verbunden ist.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:parent_type a owl:DatatypeProperty ;
    rdfs:label "parent_type" ;
    skos:definition "Type of parent object (meeting, agenda, speech, affair)" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:protocolRef a owl:ObjectProperty ;
    rdfs:label "protocol_ref" ;
    rdfs:range ops:Protocol ;
    skos:definition """[en] The protocol (minutes) of this meeting, recorded after the meeting.
[de] Das nach der Sitzung erstellte Protokoll dieser Sitzung.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:resolution_type a owl:ObjectProperty ;
    rdfs:label "resolution_type" ;
    rdfs:range ops:ResolutionTypeEnum ;
    skos:definition """[en] Type of resolutiontaken on the agenda item.
[de] Art der Resolution zum Traktandum.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:role a owl:DatatypeProperty ;
    rdfs:label "role" ;
    skos:definition "Role of the person (e.g., commission speaker)" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:seat_nr a owl:DatatypeProperty ;
    rdfs:label "seat_nr" ;
    rdfs:range xsd:string ;
    skos:definition """[en] The seat number of the individual vote, if applicable.
[de] Die Sitznummer der Einzelstimme, falls zutreffend.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:speaking_actor_id a owl:DatatypeProperty ;
    rdfs:label "speaking_actor_id" ;
    skos:definition """[en] The speaker or head of the department for the agenda item.
[de] Der Sprecher oder Departementsvorsteher für den Tagesordnungspunkt.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:start a owl:DatatypeProperty ;
    rdfs:label "start" ;
    skos:definition "Start indicator or position" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:state a owl:ObjectProperty ;
    rdfs:label "state" ;
    rdfs:range ops:StateEnum ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:state_id a owl:DatatypeProperty ;
    rdfs:label "state_id" ;
    rdfs:range xsd:string ;
    skos:definition "State identifier (reference to state enum or custom state)" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:text_format a owl:DatatypeProperty ;
    rdfs:label "text_format" ;
    skos:definition """[en] Format of text (text, html, html_with_timestamps)
[de] Format des Textes (text, html, html_with_timestamps)
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:text_type a owl:DatatypeProperty ;
    rdfs:label "text_type" ;
    skos:definition """[en] Type of text (raw draft, edited version)
[de] Typ des Textes (Rohfassung, bearbeitete Fassung)
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:tie_breaker a owl:DatatypeProperty ;
    rdfs:label "tie_breaker" ;
    rdfs:range xsd:boolean ;
    skos:definition """[en] Indicates if a tie-breaker was used in the voting.
[de] Gibt an, ob ein Stichentscheid bei der Abstimmung verwendet wurde.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_count a owl:DatatypeProperty ;
    rdfs:label "total_count" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Total number of members of the body (reference value for quorum calculations).
[de] Gesamtzahl aller Mitglieder des Gremiums (Bezugsgrösse für Quorum-Berechnungen).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_count_abstention a owl:DatatypeProperty ;
    rdfs:label "total_count_abstention" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Total number of abstentions.
[de] Gesamtzahl der Enthaltungen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_count_no a owl:DatatypeProperty ;
    rdfs:label "total_count_no" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Total number of 'no' votes.
[de] Gesamtzahl der 'Nein'-Stimmen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_count_yes a owl:DatatypeProperty ;
    rdfs:label "total_count_yes" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Total number of 'yes' votes.
[de] Gesamtzahl der 'Ja'-Stimmen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_excused a owl:DatatypeProperty ;
    rdfs:label "total_excused" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of excused absences" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_present a owl:DatatypeProperty ;
    rdfs:label "total_present" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of members present" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    skos:definition "Version number or identifier" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:voting_type a owl:ObjectProperty ;
    rdfs:label "voting_type" ;
    rdfs:range ops:VotingTypeEnum ;
    skos:definition """[en] Type of voting procedure (preliminary, final, secret, etc.).
[de] Art des Abstimmungsverfahrens (Zwischen-, Schlussabstimmung, geheim, etc.).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:weight a owl:DatatypeProperty ;
    rdfs:label "weight" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] The number of votes held by the individual, if applicable (e.g., in cases where a person has multiple votes).
[de] Die Anzahl der Stimmen, die die Einzelperson hat, falls zutreffend (z.B. in Fällen, in denen eine Person mehrere Stimmen hat).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> a owl:Class ;
    rdfs:label "MultilingualValue" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ] ;
    skos:definition """A multilingual string with language specification.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Ein mehrsprachiger String mit Angabe der Sprache.
""" ;
    ops:description_fr """Une chaîne de caractères multilingue avec indication de la langue.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateActual> a owl:DatatypeProperty ;
    rdfs:label "date_actual" ;
    rdfs:range xsd:date ;
    skos:definition """The actual date of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das tatsächliche Datum eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" ;
    ops:description_fr """La date effective d'un événement ou d'une occurrence instantané (sans durée).
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateCreated> a owl:DatatypeProperty ;
    rdfs:label "date_created" ;
    rdfs:range xsd:date ;
    skos:definition """The date when an entity was created.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das Datum, an dem eine Entität erstellt wurde.
""" ;
    ops:description_fr """La date à laquelle une entité a été créée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateModified> a owl:DatatypeProperty ;
    rdfs:label "date_modified" ;
    rdfs:range xsd:date ;
    skos:definition """The date when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das Datum, an dem eine Entität zuletzt geändert wurde.
""" ;
    ops:description_fr """La date à laquelle une entité a été modifiée pour la dernière fois.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datePlanned> a owl:DatatypeProperty ;
    rdfs:label "date_planned" ;
    rdfs:range xsd:date ;
    skos:definition """The planned date of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das geplante Datum eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" ;
    ops:description_fr """La date planifiée d'un événement ou d'une occurrence instantané (sans durée).
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The actual date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das tatsächliche Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" ;
    ops:description_fr """La date et l'heure effectives d'un événement ou d'une occurrence instantané (sans durée).
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> a owl:DatatypeProperty ;
    rdfs:label "datetime_created" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The date and time when an entity was created.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das Datum und die Uhrzeit, an dem eine Entität erstellt wurde.
""" ;
    ops:description_fr """La date et l'heure auxquelles une entité a été créée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeModified> a owl:DatatypeProperty ;
    rdfs:label "datetime_modified" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The date and time when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das Datum und die Uhrzeit, an dem eine Entität zuletzt geändert wurde.
""" ;
    ops:description_fr """La date et l'heure auxquelles une entité a été modifiée pour la dernière fois.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The planned date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das geplante Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" ;
    ops:description_fr """La date et l'heure planifiées d'un événement ou d'une occurrence instantané (sans durée).
""" .

<https://ld.ech.ch/schema/0292/meta-common/groupLabel> a owl:DatatypeProperty ;
    rdfs:label "group_label" ;
    skos:definition """Name of the body/group at time of linking.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Name des Gremiums zum Zeitpunkt der Verknüpfung.
""" ;
    ops:description_fr """Nom de l'organe/du groupe au moment de la liaison.
""" .

<https://ld.ech.ch/schema/0292/meta-common/isCurrent> a owl:DatatypeProperty ;
    rdfs:label "is_active" ;
    rdfs:range xsd:boolean ;
    skos:definition """Indicates whether the information is currently valid. Can be useful when this information is explicitly available.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Gibt an, ob die Information aktuell gültig ist. Kann nützlich sein, wenn diese Information explizit vorhanden ist.
""" ;
    ops:description_fr """Indique si l'information est actuellement valable. Peut être utile lorsque cette information est explicitement disponible.
""" .

<https://ld.ech.ch/schema/0292/meta-common/labelLong> a owl:DatatypeProperty ;
    rdfs:label "label_long" ;
    skos:definition """Assign an extended label to a structured piece of information (e.g., display name with title, position, etc.).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Möglichkeit bei einer strukturierten Information, ein erweitertesLabel zu vergeben (bspw. Anzeigename mit Titel, Anstellung, etc.).
""" ;
    ops:description_fr """Attribuer un label étendu à une information structurée (par ex. nom d'affichage avec titre, poste, etc.).
""" .

<https://ld.ech.ch/schema/0292/meta-common/remark> a owl:DatatypeProperty ;
    rdfs:label "remark" ;
    rdfs:range xsd:string ;
    skos:definition """Free-text remark or note for edge cases or additional context on a process step or an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Freitext-Bemerkung oder Notiz für Sonderfälle oder zusätzlichen Kontext zu einem Prozessschritt oder einer Entität.
""" ;
    ops:description_fr """Remarque ou note en texte libre pour les cas particuliers ou pour un contexte supplémentaire relatif à une étape de processus ou à une entité.
""" .

<https://ld.ech.ch/schema/0292/meta-common/value> a owl:DatatypeProperty ;
    rdfs:label "value" ;
    skos:definition """The value of an information besides other attributes such as type, language, etc.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Der eigentliche Wert einer Information neben weiteren attributen wie Typ, Sprache, etc.
""" ;
    ops:description_fr """La valeur proprement dite d'une information, en plus d'autres attributs tels que le type, la langue, etc.
""" .

<https://ch.paf.link/schema/meta/dates> a owl:ObjectProperty ;
    rdfs:label "dates" ;
    rdfs:range <https://ch.paf.link/schema/meta/Date> ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

ops:AgendaItem a owl:Class ;
    rdfs:label "AgendaItem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:agenda_item_number ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:agenda_item_category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:has_resolution ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:MultilingualString ;
            owl:onProperty ops:agenda_item_title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:agenda_item_number ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:agenda_item_position ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:agenda_item_position ],
        [ a owl:Restriction ;
