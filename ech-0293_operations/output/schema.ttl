            owl:onProperty ops:affair_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:AgendaItemTypeEnum ;
            owl:onProperty ops:agenda_item_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:MultilingualString ;
            owl:onProperty ops:agenda_item_description ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:state_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:affair_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:state_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:state_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:state_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:has_resolution ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:agenda_item_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:agenda_item_category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:affair_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:state_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:agenda_item_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:speaking_actor_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:speaking_actor_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:agenda_item_description ],
