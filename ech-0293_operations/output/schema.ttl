@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix ops: <https://ch.paf.link/schema/operations/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ch.paf.link/schema/meta/WorkContainer> a owl:Class ;
    rdfs:label "WorkContainer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/works> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/works> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ] ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/operations.owl.ttl> a owl:Ontology ;
    rdfs:label "operations" ;
    skos:definition """[en] Meeting Schema for various legislative bodies
[de] Sitzungs Schema für verschiedene gesetzgebende Körperschaften
""" .

ops:Container a owl:Class ;
    rdfs:label "Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ops:Protocol ;
            owl:onProperty ops:protocol ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:individualAttendance ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Election ;
            owl:onProperty ops:election ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Voting ;
            owl:onProperty ops:voting ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:agendaItem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:individualVote ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:IndividualVote ;
            owl:onProperty ops:individualVote ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:IndividualAttendance ;
            owl:onProperty ops:individualAttendance ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Session ;
            owl:onProperty ops:session ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:speech ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:meeting ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:voting ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:AgendaItem ;
            owl:onProperty ops:agendaItem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:legislature ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Legislature ;
            owl:onProperty ops:legislature ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:session ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:resolution ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Speech ;
            owl:onProperty ops:speech ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:election ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:protocol ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Resolution ;
            owl:onProperty ops:resolution ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Meeting ;
            owl:onProperty ops:meeting ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:attendance ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Attendance ;
            owl:onProperty ops:attendance ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:JointDebate a owl:Class ;
    rdfs:label "JointDebate" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ops:AgendaItem ;
            owl:onProperty ops:agendaItem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:agendaItem ] ;
    skos:definition """[en] Agenda Items which are debated together.
[de] Traktanden die gemeinsam behandelt werden.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:Media a owl:Class ;
    rdfs:label "Media" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:parent_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:media_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:MultilingualString ;
            owl:onProperty ops:url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:media_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:parent_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:media_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:parent_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:title ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """[en] Media files or documents (including protocols in PDF/HTML/WORD or links to audio/video).
[de] Mediendateien oder Dokumente (einschließlich Protokolle in PDF/HTML/WORD oder Links zu Audio/Video).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:Motion a owl:Class ;
    rdfs:label "Motion" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:title ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """[en] A formal proposal or motion submitted during proceedings.
[de] Ein formeller Antrag, der während der Verhandlungen eingereicht wird.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:agenda_item_ids a owl:DatatypeProperty ;
    rdfs:label "agenda_item_ids" ;
    rdfs:range xsd:string ;
    skos:definition """[en] The agenda items associated with the voting.
[de] Die Tagesordnungspunkte, die mit der Abstimmung verbunden sind.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:category a owl:DatatypeProperty ;
    rdfs:label "category" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:result a owl:DatatypeProperty ;
    rdfs:label "result" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> a owl:Class ;
    rdfs:label "HasTemporalValidity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/isCurrent> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/isCurrent> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <http://schema.org/validThrough> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <http://schema.org/validFrom> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/isCurrent> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <http://schema.org/validThrough> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://schema.org/validFrom> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://schema.org/validThrough> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <http://schema.org/validFrom> ] ;
    skos:definition """A mixin class that provides slots for modeling a temporal validity of information (not of an event).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Eine Mixin-Klasse, die Slots für die Modellierung einer zeitlichen Gültigkeit einer Information (nicht eines Events) zur Verfügung stellt.
""" ;
    ops:description_fr """Une classe mixin qui fournit des slots pour modéliser la validité temporelle d'une information (et non d'un événement).
""" .

<https://ld.ech.ch/schema/0292/meta-common/IsInstantaneousEvent> a owl:Class ;
    rdfs:label "IsInstantaneousEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ] ;
    skos:definition """A mixin class that provides slots for modeling instantaneous events or occurrences (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von instantanen Ereignissen oder Vorkommnissen (ohne Zeitdauer) zur Verfügung stellt.
""" ;
    ops:description_fr """Une classe mixin qui fournit des slots pour modéliser des événements ou occurrences instantanés (sans durée).
""" .

<https://ld.ech.ch/schema/0292/meta-common/IsProcessStep> a owl:Class ;
    rdfs:label "IsProcessStep" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ] ;
    skos:definition """A mixin class for a single step in a multi-stage process (e.g.,
a deliberation step of an affair or a phase step of a consultation).
Combines identification and event-duration slots and adds a free-text
remark slot. Concrete step classes add their own type-specific slots.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Eine Mixin-Klasse für einen einzelnen Schritt in einem
mehrstufigen Prozess (z. B. Bearbeitungsschritt eines Geschäfts oder
Phasen­schritt einer Konsultation). Kombiniert Identifikations- und
Zeitdauer-Slots und ergänzt einen freien Bemerkungs-Slot. Konkrete
Step-Klassen ergänzen ihre eigenen typ-spezifischen Slots.
""" ;
    ops:description_fr """Une classe mixin pour une étape unique dans un processus
à plusieurs étapes (par ex. une étape de délibération d'une affaire ou
une étape de phase d'une consultation). Combine les slots d'identification
et de durée d'événement et ajoute un slot de remarque en texte libre.
Les classes d'étape concrètes ajoutent leurs propres slots spécifiques au type.
""" .

<https://ld.ech.ch/schema/0292/meta-common/multilingualValue> a owl:ObjectProperty ;
    rdfs:label "multilingual_value" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:definition """A multilingual value with language specification.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Ein mehrsprachiger Wert mit Angabe der Sprache.
""" ;
    ops:description_fr """Une valeur multilingue avec indication de la langue.
""" .

<https://ch.paf.link/schema/meta/Expression> a owl:Class ;
    rdfs:label "Expression" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Manifestation> ;
            owl:onProperty <https://ch.paf.link/schema/meta/manifestations> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <http://schema.org/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ch.paf.link/schema/meta/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty dcterms:language ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <http://schema.org/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://schema.org/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/dates> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ) ] ;
            owl:onProperty dcterms:language ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/manifestations> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcterms:language ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Date> ;
            owl:onProperty <https://ch.paf.link/schema/meta/dates> ] ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/meta/Manifestation> a owl:Class ;
    rdfs:label "Manifestation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ch.paf.link/schema/meta/url> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Date> ;
            owl:onProperty <https://ch.paf.link/schema/meta/dates> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/dates> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
