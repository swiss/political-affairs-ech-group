<https://ld.ech.ch/schema/0292/meta-common/PersonReference> a owl:Class ;
    rdfs:label "PersonReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """Lightweight reference to a person with key identification data at time of linking. Preserves historical accuracy even if the person changes later.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Leichtgewichtige Referenz auf eine Person mit den wichtigsten Identifikationsmerkmalen zum Zeitpunkt der Verknüpfung. Ermöglicht historische Korrektheit auch wenn sich die Person später ändert.
""" ;
    ops:description_fr """Référence légère à une personne avec les principales données d'identification au moment de la liaison. Préserve l'exactitude historique même si la personne change ultérieurement.
""" .

ops:AttendanceTypeEnum a owl:Class ;
    rdfs:label "AttendanceTypeEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/attendance_type/remote> <https://ch.paf.link/schema/operations/enum/attendance_type/substitute> <https://ch.paf.link/schema/operations/enum/attendance_type/present> ) ;
