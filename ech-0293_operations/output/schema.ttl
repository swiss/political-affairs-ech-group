            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:number ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:meeting_abbreviation ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:MultilingualString ;
            owl:onProperty ops:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:parent_legislature ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:body_key ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:meeting_abbreviation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:meeting_abbreviation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:number ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:body_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ops:sequential_number ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:position ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:sequential_number ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:position ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification>,
        <https://ld.ech.ch/schema/0292/meta-common/IsEventWithDuration> ;
    skos:definition """[en] A parliamentary session that groups multiple meetings and spans a specific time period.
[de] Eine Parlamentssession, die mehrere Sitzungen gruppiert und sich über einen bestimmten Zeitraum erstreckt.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:TextSegment a owl:Class ;
    rdfs:label "TextSegment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:text ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """[en] A text segment such as cross-references or subtitles in meeting protocols.
[de] Ein Textsegment wie Querverweise oder Zwischentitel in Sitzungsprotokollen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:TotalOther a owl:Class ;
    rdfs:label "TotalOther" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ops:count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:count ] ;
    skos:definition """[en] Additional vote counts when multiple options are presented (e.g., Zurich uses 5 buttons).
[de] Zusätzliche Stimmzahlen, wenn mehrere Optionen zur Abstimmung gestellt werden (z.B. Zürich verwendet 5 Knöpfe).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

