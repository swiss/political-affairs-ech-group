            owl:allValuesFrom ops:Resolution ;
            owl:onProperty ops:has_resolution ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:agenda_item_category ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:MultilingualString ;
            owl:onProperty ops:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:parent_agenda_item ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:agenda_item_title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:url ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification>,
        <https://ld.ech.ch/schema/0292/meta-common/IsEventWithDuration> ;
    skos:definition """[en] An agenda item of a meeting.
[de] Ein Traktandum einer Sitzung.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:AgendaItemTypeEnum a owl:Class ;
    rdfs:label "AgendaItemTypeEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/agenda_item_type/item> <https://ch.paf.link/schema/operations/enum/agenda_item_type/group> ) ;
    skos:definition """[en] Type of agenda item, distinguishing individual items from grouped items.
[de] Art des Traktandums, unterscheidet einzelne von gruppierten Traktanden.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> ;
    linkml:permissible_values <https://ch.paf.link/schema/operations/enum/agenda_item_type/group>,
        <https://ch.paf.link/schema/operations/enum/agenda_item_type/item> .

ops:Attendance a owl:Class ;
    rdfs:label "Attendance" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/GroupReference> ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:datetime_begin ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty ops:datetime_begin ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:datetime_begin ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:total_present ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:total_absent ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:total_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:total_absent ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:total_present ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ops:total_absent ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:total_excused ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ops:total_excused ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ops:total_present ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty ops:total_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:total_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:total_excused ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """[en] Aggregated attendance record for a meeting (number of members present, absent, excused).
[de] Aggregierte Anwesenheitsliste für eine Sitzung (Anzahl Anwesende, Abwesende, Entschuldigte).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:DateTypesEnum a owl:Class ;
    rdfs:label "DateTypesEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/meta/vocabulary/date_types/FirstPublication> <https://ch.paf.link/schema/meta/vocabulary/date_types/LastRevision> ) ;
    skos:inScheme <https://ch.paf.link/schema/meta> ;
    linkml:permissible_values <https://ch.paf.link/schema/meta/vocabulary/date_types/FirstPublication>,
        <https://ch.paf.link/schema/meta/vocabulary/date_types/LastRevision> .

ops:Protocol a owl:Class ;
    rdfs:label "Protocol" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom ops:TextSegment ;
            owl:onProperty ops:textSegment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:voting ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Speech ;
            owl:onProperty ops:speech ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:ProtocolItem ;
            owl:onProperty ops:protocolItem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:protocolItem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:textSegment ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:speech ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:Voting ;
            owl:onProperty ops:voting ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:parent_meeting ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:parent_meeting ],
        <https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates>,
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """[en] The minutes of a meeting, recorded after the meeting. A wrapper container
     bundling the actually handled agenda items (protocol_items), votings,
     speeches, verbatim text segments and linked documents.
[de] Das nach der Sitzung erstellte Protokoll. Ein Wrapper-Container, der die
     tatsächlich behandelten Traktanden (protocol_items), Abstimmungen, Wortmeldungen,
     Wortlaut-Textsegmente und verknüpfte Dokumente bündelt.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:Resolution a owl:Class ;
    rdfs:label "Resolution" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:type_label ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:ResolutionTypeEnum ;
            owl:onProperty ops:resolution_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:type_label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:resolution_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:type_label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:resolution_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:vote_procedures ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Work> ;
            owl:onProperty <https://ch.paf.link/schema/meta/documents> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:vote_procedures ] ;
    skos:definition """[en] A resolutionor decision taken on an agenda item, including voting procedures.
[de] Eine Resolution oder Entscheidung zu einem Traktandum, einschließlich Abstimmungsverfahren.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:agendaItem a owl:ObjectProperty ;
    rdfs:label "agenda_items" ;
    rdfs:range ops:AgendaItem ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:meeting a owl:ObjectProperty ;
    rdfs:label "meetings" ;
    rdfs:range ops:Meeting ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:speech a owl:ObjectProperty ;
    rdfs:label "speeches" ;
    rdfs:range ops:Speech ;
    skos:definition "Collection of speech records" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

