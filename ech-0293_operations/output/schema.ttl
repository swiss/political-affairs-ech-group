ops:individualAttendance a owl:ObjectProperty ;
    rdfs:label "individual_attendances" ;
    rdfs:range ops:IndividualAttendance ;
    skos:definition "Collection of individual attendance records" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:individualVote a owl:ObjectProperty ;
    rdfs:label "individual_votes" ;
    rdfs:range ops:IndividualVote ;
    skos:definition "Collection of individual vote records" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:legislature a owl:ObjectProperty ;
    rdfs:label "legislatures" ;
    rdfs:range ops:Legislature ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:protocol a owl:ObjectProperty ;
    rdfs:label "protocols" ;
    rdfs:range ops:Protocol ;
    skos:definition "Collection of protocol records" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:protocolItem a owl:ObjectProperty ;
    rdfs:label "protocol_items" ;
    rdfs:range ops:ProtocolItem ;
    skos:definition """[en] Agenda items as actually recorded in the protocol.
[de] Traktanden, wie sie im Protokoll tatsächlich festgehalten wurden.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:reason a owl:ObjectProperty ;
    rdfs:label "reason" ;
    rdfs:range ops:MultilingualString ;
    skos:definition """[en] Reason for absence or lateness (free-text, multilingual).
[de] Grund für Abwesenheit oder Verspätung (Freitext, mehrsprachig).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:resolution a owl:ObjectProperty ;
    rdfs:label "resolutions" ;
    rdfs:range ops:Resolution ;
    skos:definition "Collection of resolutionrecords" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:session a owl:ObjectProperty ;
    rdfs:label "sessions" ;
    rdfs:range ops:Session ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:textSegment a owl:ObjectProperty ;
    rdfs:label "text_segments" ;
    rdfs:range ops:TextSegment ;
    skos:definition "Collection of text segments (e.g. verbatim protocol)" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_other a owl:ObjectProperty ;
    rdfs:label "total_other" ;
    rdfs:range ops:TotalOther ;
    skos:definition """[en] Used when multiple options are presented for voting (e.g., 5 buttons in Zurich).
[de] Wird verwendet, wenn mehrere Optionen zur Abstimmung gestellt werden (z.B. 5 Knöpfe in Zürich).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:vote_procedures a owl:DatatypeProperty ;
    rdfs:label "vote_procedures" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Procedures for voting, such as secret ballot or open vote.
[de] Verfahren für die Abstimmung, wie geheime Abstimmung oder offene Abstimmung.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:voting_title a owl:ObjectProperty ;
    rdfs:label "voting_title" ;
    rdfs:range ops:MultilingualString ;
    skos:definition """[en] Title or question being voted on. If no specific subject exists, do not use the business item title.
[de] Abstimmungstitel bzw. Gegenstand oder Frage. Wenn kein Gegenstand vorhanden ist, sollte nicht der Geschäftstitel verwendet werden.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ld.ech.ch/schema/0292/meta-common/abbreviation> a owl:ObjectProperty ;
    rdfs:label "abbreviation" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:definition """Abbreviation (can be multilingual).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Abkürzung (kann mehrsprachig sein).
""" ;
    ops:description_fr """Abréviation (peut être multilingue).
""" .

dcterms:date a owl:DatatypeProperty ;
    rdfs:label "xdate" ;
    rdfs:range xsd:date ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

dcterms:language a owl:DatatypeProperty ;
    rdfs:label "expression_language" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ) ] ;
    skos:definition """[en] Language code in ISO 639-1 format.
[de] Sprachcode im ISO 639-1-Format.
""" ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<http://schema.org/description> a owl:DatatypeProperty ;
    rdfs:label "expression_description" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<http://schema.org/validFrom> a owl:DatatypeProperty ;
    rdfs:label "valid_from" ;
    rdfs:range xsd:date ;
    skos:definition """The date from which the information is valid.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das Datum, ab dem die Information gültig ist.
""" ;
    ops:description_fr """La date à partir de laquelle l'information est valable.
""" .

<http://schema.org/validThrough> a owl:DatatypeProperty ;
    rdfs:label "valid_through" ;
    rdfs:range xsd:date ;
    skos:definition """The date until which the information is valid, inclusive.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das Datum, bis und mit dem die Information gültig ist.
""" ;
    ops:description_fr """La date jusqu'à laquelle l'information est valable, incluse.
""" .

<https://ch.paf.link/schema/meta/Date> a owl:Class ;
    rdfs:label "Date" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/dateType> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty dcterms:date ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/dateType> ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:DateTypesEnum ;
            owl:onProperty <https://ch.paf.link/schema/meta/dateType> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcterms:date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty dcterms:date ] ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/meta/dateType> a owl:ObjectProperty ;
    rdfs:label "date_type" ;
    rdfs:range ops:DateTypesEnum ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/meta/documentCategory> a owl:ObjectProperty ;
    rdfs:label "document_category" ;
    rdfs:range ops:DocumentCategoryEnum ;
    skos:definition """[de] Kategorie des Dokuments. Wenn nicht gesetzt, wird automatisch 'other' verwendet.
[en] Category of the document. If not set, 'other' is automatically used.
""" ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/meta/format> a owl:DatatypeProperty ;
    rdfs:label "format" ;
    rdfs:range xsd:string ;
    skos:definition """[en] The file format of the manifestation (e.g., pdf, html).
[de] Das Dateiformat der Manifestation (z.B. pdf, html).
""" ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/meta/title> a owl:DatatypeProperty ;
    rdfs:label "expression_title" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/meta/url> a owl:DatatypeProperty ;
    rdfs:label "manifestation_url" ;
    rdfs:range xsd:anyURI ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

<https://ch.paf.link/schema/meta/workType> a owl:ObjectProperty ;
    rdfs:label "work_type" ;
    rdfs:range ops:WorkTypesEnum ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

ops:Meeting a owl:Class ;
    rdfs:label "Meeting" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:sequential_number ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/GroupReference> ;
            owl:onProperty ops:group_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:actor_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:number ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:landingPage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:meeting_abbreviation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:state_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:meetingType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:administrative_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ops:actor_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:position ],
        [ a owl:Restriction ;
