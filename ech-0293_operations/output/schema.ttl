            owl:onProperty ops:state_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:MeetingTypeEnum ;
            owl:onProperty ops:meetingType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:group_name ],
        [ a owl:Restriction ;
