ops:WorkTypesEnum a owl:Class ;
    rdfs:label "WorkTypesEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/meta/vocabulary/work_types/PV> <https://ch.paf.link/schema/meta/vocabulary/work_types/SubmittedVersion> <https://ch.paf.link/schema/meta/vocabulary/work_types/CurrentLaw> ) ;
    skos:inScheme <https://ch.paf.link/schema/meta> ;
    linkml:permissible_values <https://ch.paf.link/schema/meta/vocabulary/work_types/CurrentLaw>,
        <https://ch.paf.link/schema/meta/vocabulary/work_types/PV>,
        <https://ch.paf.link/schema/meta/vocabulary/work_types/SubmittedVersion> .

ops:MajorityTypeEnum a owl:Class ;
    rdfs:label "MajorityTypeEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/majority_type/absolute> <https://ch.paf.link/schema/operations/enum/majority_type/two_thirds> <https://ch.paf.link/schema/operations/enum/majority_type/other> ) ;
    skos:definition "Type of majority required for the vote" ;
    skos:inScheme <https://ch.paf.link/schema/operations> ;
    linkml:permissible_values <https://ch.paf.link/schema/operations/enum/majority_type/absolute>,
        <https://ch.paf.link/schema/operations/enum/majority_type/other>,
        <https://ch.paf.link/schema/operations/enum/majority_type/two_thirds> .

ops:MeetingTypeEnum a owl:Class ;
    rdfs:label "MeetingTypeEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/meeting_type/session> <https://ch.paf.link/schema/operations/enum/meeting_type/committee> <https://ch.paf.link/schema/operations/enum/meeting_type/sitting> <https://ch.paf.link/schema/operations/enum/meeting_type/various> ) ;
    skos:definition "Type of the meeting" ;
    skos:inScheme <https://ch.paf.link/schema/operations> ;
    linkml:permissible_values <https://ch.paf.link/schema/operations/enum/meeting_type/committee>,
        <https://ch.paf.link/schema/operations/enum/meeting_type/session>,
        <https://ch.paf.link/schema/operations/enum/meeting_type/sitting>,
        <https://ch.paf.link/schema/operations/enum/meeting_type/various> .

ops:administrative_id a owl:DatatypeProperty ;
    rdfs:label "administrative_id" ;
    skos:definition """[en] Administrative ID of the legislative body, such as a municipality, canton, or country.
[de] Verwaltungs-ID des gesetzgebenden Körpers, wie z.B. Gemeinde, Kanton oder Land.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:body_key a owl:DatatypeProperty ;
    rdfs:label "body_key" ;
    skos:definition """[en] Key identifying the political body or jurisdiction (e.g., BE for Bern, CHE for Switzerland).
[de] Schlüssel zur Identifizierung des politischen Organs oder der Gerichtsbarkeit (z.B. BE für Bern, CHE für Schweiz).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:majority_count a owl:DatatypeProperty ;
    rdfs:label "majority_count" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Number of votes required for the relevant majority threshold.
[de] Anzahl der Stimmen, die für die relevante Mehrheitsschwelle erforderlich sind.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:majority_type a owl:ObjectProperty ;
    rdfs:label "majority_type" ;
    rdfs:range ops:MajorityTypeEnum ;
    skos:definition """[en] Type of majority required for the vote (absolute, two-thirds, etc.).
[de] Art der für die Abstimmung erforderlichen Mehrheit (absolut, Zweidrittel usw.).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:media_type a owl:DatatypeProperty ;
    rdfs:label "media_type" ;
    skos:definition "Type of media (audio, video, document)" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:meeting_abbreviation a owl:DatatypeProperty ;
    rdfs:label "meeting_abbreviation" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:name a owl:ObjectProperty ;
    rdfs:label "name" ;
    rdfs:range ops:MultilingualString ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:number a owl:DatatypeProperty ;
    rdfs:label "number" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:parent_legislature a owl:DatatypeProperty ;
    rdfs:label "parent_legislature" ;
    skos:definition """[en] The legislative body in which the meeting is based.
[de] Der gesetzgebende Körper, auf dem die Sitzung basiert.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:position a owl:DatatypeProperty ;
    rdfs:label "position" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:result_text a owl:DatatypeProperty ;
    rdfs:label "result_text" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Free text describing the outcome of the vote, e.g., "Accepted with 78 votes".
[de] Freitext zur Beschreibung des Ergebnisses der Abstimmung, z.B. "Mit 78 Stimmen angenommen".
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:sequential_number a owl:DatatypeProperty ;
    rdfs:label "sequential_number" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Sequential number of the meeting, used for ordering.
[de] Laufende Nummer der Sitzung, die zur Sortierung verwendet wird.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:state_name a owl:DatatypeProperty ;
    rdfs:label "state_name" ;
    rdfs:range xsd:string ;
    skos:definition """[en] Custom state description for the meeting.
[de] Benutzerdefinierte Zustandsbeschreibung für die Sitzung.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total a owl:DatatypeProperty ;
    rdfs:label "total" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Total number of votes, excluding absent and president's vote.
[de] Gesamtzahl der Stimmen, ohne abwesende und Präsidentenstimmen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> a owl:DatatypeProperty ;
    rdfs:label "date_begin_actual" ;
    rdfs:range xsd:date ;
    skos:definition """The actual start date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das tatsächliche Startdatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date de début effective d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> a owl:DatatypeProperty ;
    rdfs:label "date_begin_planned" ;
    rdfs:range xsd:date ;
    skos:definition """The planned start date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das geplante Startdatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date de début planifiée d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateEndActual> a owl:DatatypeProperty ;
    rdfs:label "date_end_actual" ;
    rdfs:range xsd:date ;
    skos:definition """The actual end date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das tatsächliche Enddatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date de fin effective d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> a owl:DatatypeProperty ;
    rdfs:label "date_end_planned" ;
    rdfs:range xsd:date ;
    skos:definition """The planned end date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das geplante Enddatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date de fin planifiée d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_begin_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The actual start date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das tatsächliche Startdatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date et l'heure de début effectives d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_begin_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The planned start date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das geplante Startdatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date et l'heure de début planifiées d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_end_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The actual end date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das tatsächliche Enddatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date et l'heure de fin effectives d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_end_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The planned end date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Das geplante Enddatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" ;
    ops:description_fr """La date et l'heure de fin planifiées d'un événement ou d'une occurrence avec durée.
""" .

<https://ld.ech.ch/schema/0292/meta-common/globalURI> a owl:DatatypeProperty ;
    rdfs:label "global_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """A unique, globally valid URI for the entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Eine eindeutige, global gültige URI für die Entität.
""" ;
    ops:description_fr """Une URI unique et globalement valide pour l'entité.
""" .

<https://ld.ech.ch/schema/0292/meta-common/localId> a owl:DatatypeProperty ;
    rdfs:label "local_id" ;
    skos:definition """Local identifier. For example, a UUID from the council information system.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Lokaler Identifikator. Bspw. eine UUID aus dem Ratsinformationssystem.
""" ;
    ops:description_fr """Identifiant local. Par exemple, un UUID issu du système d'information du conseil.
""" .

<https://ld.ech.ch/schema/0292/meta-common/wikidataUri> a owl:DatatypeProperty ;
    rdfs:label "wikidata_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """A URI that refers to a Wikidata entity, e.g. http://www.wikidata.org/entity/Q39 for Switzerland.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Eine URI, die auf eine Wikidata-Entität verweist, z.B. http://www.wikidata.org/entity/Q39 für die Schweiz.
""" ;
    ops:description_fr """Une URI qui renvoie à une entité Wikidata, par ex. http://www.wikidata.org/entity/Q39 pour la Suisse.
""" .

ops:VotingTypeEnum a owl:Class ;
    rdfs:label "VotingTypeEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/voting_type/preliminary_vote> <https://ch.paf.link/schema/operations/enum/voting_type/final_vote> <https://ch.paf.link/schema/operations/enum/voting_type/tie_breaker_president> <https://ch.paf.link/schema/operations/enum/voting_type/secret_vote> <https://ch.paf.link/schema/operations/enum/voting_type/other> ) ;
    skos:definition """[en] Type of voting procedure.
[de] Art des Abstimmungsverfahrens.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> ;
    linkml:permissible_values <https://ch.paf.link/schema/operations/enum/voting_type/final_vote>,
        <https://ch.paf.link/schema/operations/enum/voting_type/other>,
        <https://ch.paf.link/schema/operations/enum/voting_type/preliminary_vote>,
        <https://ch.paf.link/schema/operations/enum/voting_type/secret_vote>,
        <https://ch.paf.link/schema/operations/enum/voting_type/tie_breaker_president> .

<https://ld.ech.ch/schema/0292/meta-common/GroupReference> a owl:Class ;
    rdfs:label "GroupReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/abbreviation> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/abbreviation> ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """Lightweight reference to a group with key identification data at time of linking.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Leichtgewichtige Referenz auf eine Gruppe mit den wichtigsten Identifikationsmerkmalen zum Zeitpunkt der Verknüpfung.
""" ;
    ops:description_fr """Référence légère à un groupe avec les principales données d'identification au moment de la liaison.
""" .

ops:IndividualVoteTypeEnum a owl:Class ;
    rdfs:label "IndividualVoteTypeEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/individual_vote_type/yes> <https://ch.paf.link/schema/operations/enum/individual_vote_type/no> <https://ch.paf.link/schema/operations/enum/individual_vote_type/abstention> <https://ch.paf.link/schema/operations/enum/individual_vote_type/not_voted> <https://ch.paf.link/schema/operations/enum/individual_vote_type/tie_breaker> <https://ch.paf.link/schema/operations/enum/individual_vote_type/other> ) ;
    skos:definition """[en] Type of individual vote cast by a member.
[de] Art der Einzelstimme eines Mitglieds.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> ;
    linkml:permissible_values <https://ch.paf.link/schema/operations/enum/individual_vote_type/abstention>,
        <https://ch.paf.link/schema/operations/enum/individual_vote_type/no>,
        <https://ch.paf.link/schema/operations/enum/individual_vote_type/not_voted>,
        <https://ch.paf.link/schema/operations/enum/individual_vote_type/other>,
        <https://ch.paf.link/schema/operations/enum/individual_vote_type/tie_breaker>,
        <https://ch.paf.link/schema/operations/enum/individual_vote_type/yes> .

ops:url a owl:ObjectProperty ;
    rdfs:label "url" ;
    rdfs:range ops:MultilingualString ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:affair_id a owl:DatatypeProperty ;
    rdfs:label "affair_id" ;
    rdfs:range xsd:string ;
    skos:definition """[en] The connection to the affairs (business items) of the agenda item.
[de] Die Verbindung zu den Geschäften (Geschäftsgegenständen) des Tagesordnungspunkts.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:datetime_end a owl:DatatypeProperty ;
    rdfs:label "datetime_end" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[en] The date and time when the meeting or voting ends.
[de] Das Datum und die Uhrzeit, zu der die Sitzung oder Abstimmung endet.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:parent_agenda_item a owl:DatatypeProperty ;
    rdfs:label "parent_agenda_item" ;
    rdfs:range xsd:string ;
    skos:definition """[en] If needed, this slot builds a hierarchy of agenda items.
[de] Wenn erforderlich, baut dieser Slot eine Hierarchie von Tagesordnungspunkten auf.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:total_absent a owl:DatatypeProperty ;
    rdfs:label "total_absent" ;
    rdfs:range xsd:integer ;
    skos:definition """[en] Total number of absent members. Distinction between absent/excused absent - presence is tracked on attendance list.
[de] Gesamtzahl abwesender Mitglieder. Unterscheidung zwischen abwesend/entschuldigt abwesend - Anwesenheit wird auf Anwesenheitsliste verfolgt.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ld.ech.ch/schema/0292/meta-common/label> a owl:DatatypeProperty ;
    rdfs:label "label" ;
    skos:definition """Assign a label to a structured piece of information (e.g., display name, position, etc.).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Möglichkeit bei einer strukturierten Information, ein Label zu vergeben (bspw. Anzeigename, Anstellung, etc.).
""" ;
    ops:description_fr """Attribuer un label à une information structurée (par ex. nom d'affichage, poste, etc.).
""" .

<https://ld.ech.ch/schema/0292/meta-common/language> a owl:DatatypeProperty ;
    rdfs:label "language" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
    skos:definition """Language code in ISO 639-1 format (two lowercase letters, e.g. "de", "fr", "it", "en").
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Sprachcode im ISO 639-1 Format (zwei Kleinbuchstaben, z.B. "de", "fr", "it", "en").
""" ;
    ops:description_fr """Code de langue au format ISO 639-1 (deux lettres minuscules, par ex. « de », « fr », « it », « en »).
""" .

ops:ResolutionTypeEnum a owl:Class ;
    rdfs:label "ResolutionTypeEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/operations/enum/resolution_type/accepted> <https://ch.paf.link/schema/operations/enum/resolution_type/rejected> <https://ch.paf.link/schema/operations/enum/resolution_type/noted> <https://ch.paf.link/schema/operations/enum/resolution_type/accepted_point_by_point> <https://ch.paf.link/schema/operations/enum/resolution_type/accepted_with_postulate> <https://ch.paf.link/schema/operations/enum/resolution_type/orally_settled> <https://ch.paf.link/schema/operations/enum/resolution_type/nearly_unanimous> <https://ch.paf.link/schema/operations/enum/resolution_type/other> ) ;
    skos:definition """[en] Type of resolutiontaken on an agenda item.
[de] Art der Resolution zu einem Traktandum.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> ;
    linkml:permissible_values <https://ch.paf.link/schema/operations/enum/resolution_type/accepted>,
        <https://ch.paf.link/schema/operations/enum/resolution_type/accepted_point_by_point>,
        <https://ch.paf.link/schema/operations/enum/resolution_type/accepted_with_postulate>,
        <https://ch.paf.link/schema/operations/enum/resolution_type/nearly_unanimous>,
        <https://ch.paf.link/schema/operations/enum/resolution_type/noted>,
        <https://ch.paf.link/schema/operations/enum/resolution_type/orally_settled>,
        <https://ch.paf.link/schema/operations/enum/resolution_type/other>,
        <https://ch.paf.link/schema/operations/enum/resolution_type/rejected> .

<https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates> a owl:Class ;
    rdfs:label "HasCreationModificationDates" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ] ;
    skos:definition """A mixin class that provides slots for modeling creation and modification dates of an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von Erstellungs- und Änderungsdaten einer Entität zur Verfügung stellt.
""" ;
    ops:description_fr """Une classe mixin qui fournit des slots pour modéliser les dates de création et de modification d'une entité.
""" .

<https://ch.paf.link/schema/meta/id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

ops:DocumentCategoryEnum a owl:Class ;
    rdfs:label "DocumentCategoryEnum" ;
    owl:unionOf ( <https://ch.paf.link/schema/meta/vocabulary/document_category/Protocol> <https://ch.paf.link/schema/meta/vocabulary/document_category/VotingResult> <https://ch.paf.link/schema/meta/vocabulary/document_category/MeetingDocuments> <https://ch.paf.link/schema/meta/vocabulary/document_category/MeetingPlanning> <https://ch.paf.link/schema/meta/vocabulary/document_category/MediaRelease> <https://ch.paf.link/schema/meta/vocabulary/document_category/GroupDocuments> <https://ch.paf.link/schema/meta/vocabulary/document_category/MemberDirectory> <https://ch.paf.link/schema/meta/vocabulary/document_category/PersonDocuments> <https://ch.paf.link/schema/meta/vocabulary/document_category/InterestDisclosure> <https://ch.paf.link/schema/meta/vocabulary/document_category/Other> ) ;
    skos:definition """[de] Kategorien zur Klassifikation von Dokumenten, die in den eCH Standards 0292-0297 referenziert werden. Mehrsprachige Labels (DE/FR/IT/RM/EN) sind über `annotations` (Konvention `label_xx`) abgebildet; Erstvorschläge für FR/IT/RM stehen unter Plenum-Review.
[en] Categories for classifying documents referenced in eCH standards 0292-0297. Multilingual labels (DE/FR/IT/RM/EN) are encoded via `annotations` (convention `label_xx`); first proposals for FR/IT/RM are pending plenum review.
""" ;
    skos:inScheme <https://ch.paf.link/schema/meta> ;
    linkml:permissible_values <https://ch.paf.link/schema/meta/vocabulary/document_category/GroupDocuments>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/InterestDisclosure>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/MediaRelease>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/MeetingDocuments>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/MeetingPlanning>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/MemberDirectory>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/Other>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/PersonDocuments>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/Protocol>,
        <https://ch.paf.link/schema/meta/vocabulary/document_category/VotingResult> .

ops:datetime_begin a owl:DatatypeProperty ;
    rdfs:label "datetime_begin" ;
    rdfs:range xsd:dateTime ;
    skos:definition """[en] The date and time when the meeting or voting begins.
[de] Das Datum und die Uhrzeit, zu der die Sitzung oder Abstimmung beginnt.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:type_label a owl:DatatypeProperty ;
    rdfs:label "type_label" ;
    skos:definition """[en] Custom type label when standard type values don't apply.
[de] Benutzerdefinierte Typbezeichnung, wenn Standardtypwerte nicht zutreffen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ch.paf.link/schema/meta/Work> a owl:Class ;
    rdfs:label "Work" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/workType> ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:DocumentCategoryEnum ;
            owl:onProperty <https://ch.paf.link/schema/meta/documentCategory> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/documentCategory> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom ops:WorkTypesEnum ;
            owl:onProperty <https://ch.paf.link/schema/meta/workType> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/expressions> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ch.paf.link/schema/meta/Expression> ;
            owl:onProperty <https://ch.paf.link/schema/meta/expressions> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/workType> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ch.paf.link/schema/meta/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ch.paf.link/schema/meta/documentCategory> ] ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

ops:MultilingualString a owl:Class ;
    rdfs:label "MultilingualString" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ops:text ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ] ;
    skos:definition """[en] A string that can contain text in multiple languages.
[de] Ein String, der Text in mehreren Sprachen enthalten kann.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ld.ech.ch/schema/0292/meta-common/HasIdentification> a owl:Class ;
    rdfs:label "HasIdentification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ] ;
    skos:definition """A mixin class that provides slots for the identification of an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    ops:description_de """Eine Mixin-Klasse, die Slots für die Identifikation einer Entität zur Verfügung stellt.
""" ;
    ops:description_fr """Une classe mixin qui fournit des slots pour l'identification d'une entité.
""" .

ops:landingPage a owl:DatatypeProperty ;
    rdfs:label "landing_page" ;
    skos:definition """[en] URL providing further information.
[de] URL mit weiteren Informationen.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

ops:parent_meeting a owl:DatatypeProperty ;
    rdfs:label "parent_meeting" ;
    rdfs:range xsd:string ;
    skos:definition """[en] The linked meeting ID that groups the current meeting.
[de] Die verknüpfte Sitzungs-ID, die die aktuelle Sitzung gruppiert.
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .

<https://ch.paf.link/schema/meta/documents> a owl:ObjectProperty ;
    rdfs:label "documents" ;
    rdfs:range <https://ch.paf.link/schema/meta/Work> ;
    skos:definition """[de] Liste von Dokumenten (FRBR Works), die mit der Entität verknüpft sind.
[en] List of documents (FRBR Works) linked to the entity.
""" ;
    skos:inScheme <https://ch.paf.link/schema/meta> .

ops:actor_id a owl:ObjectProperty ;
    rdfs:label "actor_id" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/PersonReference> ;
    skos:definition """[en] Reference to the acting person (lightweight snapshot at time of linking).
[de] Referenz auf die handelnde Person (leichtgewichtiger Snapshot zum Zeitpunkt der Verknüpfung).
""" ;
    skos:inScheme <https://ch.paf.link/schema/operations> .


