ops:366631 a ops:Speech ;
    ops:actor_fullname "Pascal Broulis" ;
    ops:actor_id <https://api.openparldata.ch/v1/persons/18682> ;
    ops:datetime_begin "2025-12-19T09:20:00+01:00"^^xsd:dateTime ;
    ops:datetime_end "2025-12-19T09:25:00+01:00"^^xsd:dateTime ;
    ops:landingPage "https://www.parlament.ch/de/ratsbetrieb/amtliches-bulletin/amtliches-bulletin-die-videos?TranscriptId=366631" ;
    ops:media_format "video/mp4" ;
    ops:media_type "video" ;
    ops:media_url "https://par-pcache.simplex.tv/content?externalid=366631" ;
    ops:role "speaker" ;
    ops:text "Je remercie la rapporteuse pour son rapport exhaustif. J'ai également lu avec attention les différents commentaires qui ont été effectués sur mon postulat. Cela reste un postulat, ce n'est pas une motion. D'abord, je ne partage pas l'avis selon lequel ce postulat n'apporterait pas une valeur ajoutée. En effet, un \"benchmark\", à savoir un modèle chiffré de performance, permettrait de mieux comprendre les raisons des retards que notre pays rencontre en comparaison avec les principaux pays européens." ;
    ops:text_format "html" ;
    ops:text_type "final" ;
    mcm:language "fr" .

