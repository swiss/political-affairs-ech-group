ops:7b3545e4-57dc-3901-aaa8-4020da6ab0c6 a ops:AgendaItem ;
    ops:agenda_item_description [ a ops:MultilingualString ;
            ops:text """Le Conseil d'Etat approuve le projet de révision partielle de sept ordonnances fédérales relatives aux produits chimiques. Il salue la volonté des autorités fédérales d'introduire dans la législation fédérale les modifications nécessaires découlant des nouveaux règlements européens, afin d'éliminer des entraves au commerce et d'augmenter la sécurité d'évaluation des produits chimiques.
""" ;
            mcm:language "fr" ] ;
    ops:agenda_item_number "7" ;
    ops:agenda_item_position 7 ;
    ops:agenda_item_title [ a ops:MultilingualString ;
            ops:text "Révision partielle de sept ordonnances fédérales relatives aux produits chimiques" ;
            mcm:language "fr" ] ;
    ops:agenda_item_type <https://ch.paf.link/schema/operations/enum/agenda_item_type/item> ;
    ops:parent_meeting "ops:meeting_vaud_2008_04_30" ;
    ops:url [ a ops:MultilingualString ;
            ops:text "https://www.vd.ch/actualites/decisions-du-conseil-detat/seance-du-conseil-detat/seance/265632#7b3545e4-57dc-3901-aaa8-4020da6ab0c6" ;
