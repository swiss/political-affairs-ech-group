@prefix mcm: <https://ld.ech.ch/schema/0292/meta-common/> .
@prefix schema1: <http://schema.org/> .
@prefix tutorial: <https://ch.paf.link/schema/tutorial/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tutorial:s2025 a tutorial:Container ;
    tutorial:agendaItem tutorial:s2025-1_t1,
        tutorial:s2025-2_t1 ;
    tutorial:session tutorial:s2025-1,
        tutorial:s2025-2 ;
    tutorial:vote tutorial:s2025-1_t1_a1,
        tutorial:s2025-1_t1_a2,
        tutorial:s2025-2_t1_a1 .

tutorial:s2025-1 a tutorial:Session ;
    schema1:name [ a mcm:MultilingualValue ;
            mcm:language "de" ;
            mcm:value "Frühlingssession 2025" ],
        [ a mcm:MultilingualValue ;
            mcm:language "en" ;
            mcm:value "Spring Session 2025" ] ;
    mcm:dateBeginActual "2025-03-01"^^xsd:date ;
    mcm:dateEndActual "2025-04-10"^^xsd:date .

tutorial:s2025-1_t1_a1 a tutorial:Vote ;
    tutorial:is_part_of tutorial:s2025-1_t1 ;
    tutorial:is_part_of_agenda_item tutorial:s2025-1_t1 ;
    tutorial:question "Soll die Farbe geändert werden?" .

tutorial:s2025-1_t1_a2 a tutorial:Vote ;
    tutorial:is_part_of tutorial:s2025-1_t1 ;
    tutorial:is_part_of_agenda_item tutorial:s2025-1_t1 ;
    tutorial:question "Soll die Farbe Auberginen-Oliv werden?" .

tutorial:s2025-2 a tutorial:Session ;
    schema1:name [ a mcm:MultilingualValue ;
            mcm:language "en" ;
            mcm:value "Summer Session 2025" ],
        [ a mcm:MultilingualValue ;
            mcm:language "de" ;
            mcm:value "Sommersession 2025" ] ;
    mcm:dateBeginActual "2025-06-01"^^xsd:date ;
    mcm:dateEndActual "2025-07-10"^^xsd:date .

tutorial:s2025-2_t1_a1 a tutorial:Vote ;
    tutorial:is_part_of tutorial:s2025-2_t1 ;
    tutorial:is_part_of_agenda_item tutorial:s2025-2_t1 ;
    tutorial:question "Soll die Hymne geändert werden?" .

tutorial:s2025-2_t1 a tutorial:AgendaItem ;
    schema1:name [ a mcm:MultilingualValue ;
            mcm:language "de" ;
            mcm:value "Landeshymne" ] .

tutorial:s2025-1_t1 a tutorial:AgendaItem ;
    schema1:name [ a mcm:MultilingualValue ;
            mcm:language "de" ;
            mcm:value "Fahnenfarbe" ] .


