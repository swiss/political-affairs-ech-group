    rdfs:label "date_planned" ;
    rdfs:range xsd:date ;
    skos:definition """The planned date of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das geplante Datum eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_begin_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The actual start date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das tatsächliche Startdatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_begin_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The planned start date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das geplante Startdatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> a owl:DatatypeProperty ;
    rdfs:label "datetime_created" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The date and time when an entity was created.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das Datum und die Uhrzeit, an dem eine Entität erstellt wurde.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_end_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The actual end date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das tatsächliche Enddatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_end_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The planned end date and time of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das geplante Enddatum und die Uhrzeit eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeModified> a owl:DatatypeProperty ;
    rdfs:label "datetime_modified" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The date and time when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das Datum und die Uhrzeit, an dem eine Entität zuletzt geändert wurde.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> a owl:DatatypeProperty ;
    rdfs:label "datetime_planned" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The planned date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das geplante Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/globalURI> a owl:DatatypeProperty ;
    rdfs:label "global_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """A unique, globally valid URI for the entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine eindeutige, global gültige URI für die Entität.
""" .

<https://ld.ech.ch/schema/0292/meta-common/groupLabel> a owl:DatatypeProperty ;
    rdfs:label "group_label" ;
    skos:definition """Name of the body/group at time of linking.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Name des Gremiums zum Zeitpunkt der Verknüpfung.
""" .

<https://ld.ech.ch/schema/0292/meta-common/isCurrent> a owl:DatatypeProperty ;
    rdfs:label "is_active" ;
    rdfs:range xsd:boolean ;
    skos:definition """Indicates whether the information is currently valid. Can be useful when this information is explicitly available.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Gibt an, ob die Information aktuell gültig ist. Kann nützlich sein, wenn diese Information explizit vorhanden ist.
""" .

<https://ld.ech.ch/schema/0292/meta-common/labelLong> a owl:DatatypeProperty ;
    rdfs:label "label_long" ;
    skos:definition """Assign an extended label to a structured piece of information (e.g., display name with title, position, etc.).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Möglichkeit bei einer strukturierten Information, ein erweitertesLabel zu vergeben (bspw. Anzeigename mit Titel, Anstellung, etc.).
""" .

<https://ld.ech.ch/schema/0292/meta-common/language> a owl:DatatypeProperty ;
    rdfs:label "language" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
    skos:definition """Language code in ISO 639-1 format (two lowercase letters, e.g. "de", "fr", "it", "en").
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Sprachcode im ISO 639-1 Format (zwei Kleinbuchstaben, z.B. "de", "fr", "it", "en").
""" .

<https://ld.ech.ch/schema/0292/meta-common/localId> a owl:DatatypeProperty ;
    rdfs:label "local_id" ;
    skos:definition """Local identifier. For example, a UUID from the council information system.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Lokaler Identifikator. Bspw. eine UUID aus dem Ratsinformationssystem.
""" .

<https://ld.ech.ch/schema/0292/meta-common/remark> a owl:DatatypeProperty ;
    rdfs:label "remark" ;
    rdfs:range xsd:string ;
    skos:definition """Free-text remark or note for edge cases or additional context on a process step or an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Freitext-Bemerkung oder Notiz für Sonderfälle oder zusätzlichen Kontext zu einem Prozessschritt oder einer Entität.
""" .

<https://ld.ech.ch/schema/0292/meta-common/value> a owl:DatatypeProperty ;
    rdfs:label "value" ;
    skos:definition """The value of an information besides other attributes such as type, language, etc.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Der eigentliche Wert einer Information neben weiteren attributen wie Typ, Sprache, etc.
""" .

<https://ld.ech.ch/schema/0292/meta-common/wikidataUri> a owl:DatatypeProperty ;
    rdfs:label "wikidata_uri" ;
    rdfs:range xsd:anyURI ;
    skos:definition """A URI that refers to a Wikidata entity, e.g. https://www.wikidata.org/wiki/Q39 for Switzerland.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine URI, die auf eine Wikidata-Entität verweist, z.B. https://www.wikidata.org/wiki/Q39 für die Schweiz.
""" .

<http://schema.org/name> a owl:ObjectProperty ;
    rdfs:label "name" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:AgendaItem a owl:Class ;
    rdfs:label "AgendaItem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom tutorial:Vote ;
            owl:onProperty tutorial:vote ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <http://schema.org/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:vote ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
            owl:onProperty <http://schema.org/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty tutorial:id ] ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:ResultEnum a owl:Class ;
    rdfs:label "result_enum" ;
    owl:unionOf ( <https://ch.paf.link/schema/tutorial/results/yes> <https://ch.paf.link/schema/tutorial/results/no> ) ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> ;
    linkml:permissible_values <https://ch.paf.link/schema/tutorial/results/no>,
        <https://ch.paf.link/schema/tutorial/results/yes> .

tutorial:agendaItem a owl:ObjectProperty ;
    rdfs:label "agenda_items" ;
    rdfs:range tutorial:AgendaItem ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:vote a owl:ObjectProperty ;
    rdfs:label "votes" ;
    rdfs:range tutorial:Vote ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

<https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> a owl:Class ;
    rdfs:label "MultilingualValue" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-z]{2}$" ] ) ] ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/language> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/value> ] ;
    skos:definition """A multilingual string with language specification.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Ein mehrsprachiger String mit Angabe der Sprache.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> a owl:DatatypeProperty ;
    rdfs:label "date_begin_actual" ;
    rdfs:range xsd:date ;
    skos:definition """The actual start date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das tatsächliche Startdatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateEndActual> a owl:DatatypeProperty ;
    rdfs:label "date_end_actual" ;
    rdfs:range xsd:date ;
    skos:definition """The actual end date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das tatsächliche Enddatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

<https://ld.ech.ch/schema/0292/meta-common/datetimeActual> a owl:DatatypeProperty ;
    rdfs:label "datetime_actual" ;
    rdfs:range xsd:dateTime ;
    skos:definition """The actual date and time of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das tatsächliche Datum und die Uhrzeit eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/label> a owl:DatatypeProperty ;
    rdfs:label "label" ;
    skos:definition """Assign a label to a structured piece of information (e.g., display name, position, etc.).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Möglichkeit bei einer strukturierten Information, ein Label zu vergeben (bspw. Anzeigename, Anstellung, etc.).
""" .

tutorial:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .


