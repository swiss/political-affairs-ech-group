    rdfs:label "date_created" ;
    rdfs:range xsd:date ;
    skos:definition """The date when an entity was created.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das Datum, an dem eine Entität erstellt wurde.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> a owl:DatatypeProperty ;
    rdfs:label "date_end_planned" ;
    rdfs:range xsd:date ;
    skos:definition """The planned end date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das geplante Enddatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateModified> a owl:DatatypeProperty ;
    rdfs:label "date_modified" ;
    rdfs:range xsd:date ;
    skos:definition """The date when an entity was last modified.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das Datum, an dem eine Entität zuletzt geändert wurde.
""" .

