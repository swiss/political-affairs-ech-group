@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tutorial: <https://ch.paf.link/schema/tutorial/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ch.paf.link/schema/tutorial.owl.ttl> a owl:Ontology ;
    rdfs:label "tutorial" ;
    skos:definition """[en] This is a dummy schema for a parliamentary affairs system, including sessions, agenda items, and votes. It is used to demonstrate the use of LinkML for defining data models. In this model, a session contains multiple agenda items and each agenda item can have multiple votes.
[de] Dies ist ein Dummy-Schema für ein System von parlamentarischen Angelegenheiten, das Sitzungen, Tagesordnungspunkte und Abstimmungen umfasst. Es wird verwendet, um die Verwendung von LinkML zur Definition von Datenmodellen zu demonstrieren. In diesem Modell enthält eine Sitzung mehrere Tagesordnungspunkte und jeder Tagesordnungspunkt kann mehrere Abstimmungen haben.
""" .

tutorial:Container a owl:Class ;
    rdfs:label "Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom tutorial:Session ;
            owl:onProperty tutorial:session ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:vote ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:session ],
        [ a owl:Restriction ;
            owl:allValuesFrom tutorial:AgendaItem ;
            owl:onProperty tutorial:agendaItem ],
        [ a owl:Restriction ;
            owl:allValuesFrom tutorial:Vote ;
            owl:onProperty tutorial:vote ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:agendaItem ] ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

<https://ld.ech.ch/schema/0292/meta-common/GroupReference> a owl:Class ;
    rdfs:label "GroupReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/abbreviation> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/abbreviation> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """Lightweight reference to a group with key identification data at time of linking.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Leichtgewichtige Referenz auf eine Gruppe mit den wichtigsten Identifikationsmerkmalen zum Zeitpunkt der Verknüpfung.
""" .

<https://ld.ech.ch/schema/0292/meta-common/HasCreationModificationDates> a owl:Class ;
    rdfs:label "HasCreationModificationDates" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateModified> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateCreated> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeCreated> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeModified> ] ;
    skos:definition """A mixin class that provides slots for modeling creation and modification dates of an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von Erstellungs- und Änderungsdaten einer Entität zur Verfügung stellt.
""" .

<https://ld.ech.ch/schema/0292/meta-common/HasTemporalValidity> a owl:Class ;
    rdfs:label "HasTemporalValidity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/isCurrent> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://schema.org/validThrough> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <http://schema.org/validThrough> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/isCurrent> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <http://schema.org/validFrom> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/isCurrent> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <http://schema.org/validFrom> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <http://schema.org/validFrom> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <http://schema.org/validThrough> ] ;
    skos:definition """A mixin class that provides slots for modeling a temporal validity of information (not of an event).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine Mixin-Klasse, die Slots für die Modellierung einer zeitlichen Gültigkeit einer Information (nicht eines Events) zur Verfügung stellt.
""" .

<https://ld.ech.ch/schema/0292/meta-common/IsInstantaneousEvent> a owl:Class ;
    rdfs:label "IsInstantaneousEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datePlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimePlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateActual> ] ;
    skos:definition """A mixin class that provides slots for modeling instantaneous events or occurrences (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von instantanen Ereignissen oder Vorkommnissen (ohne Zeitdauer) zur Verfügung stellt.
""" .

<https://ld.ech.ch/schema/0292/meta-common/IsProcessStep> a owl:Class ;
    rdfs:label "IsProcessStep" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/remark> ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification>,
        <https://ld.ech.ch/schema/0292/meta-common/IsEventWithDuration> ;
    skos:definition """A mixin class for a single step in a multi-stage process (e.g.,
a deliberation step of an affair or a phase step of a consultation).
Combines identification and event-duration slots and adds a free-text
remark slot. Concrete step classes add their own type-specific slots.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine Mixin-Klasse für einen einzelnen Schritt in einem
mehrstufigen Prozess (z. B. Bearbeitungsschritt eines Geschäfts oder
Phasen­schritt einer Konsultation). Kombiniert Identifikations- und
Zeitdauer-Slots und ergänzt einen freien Bemerkungs-Slot. Konkrete
Step-Klassen ergänzen ihre eigenen typ-spezifischen Slots.
""" .

<https://ld.ech.ch/schema/0292/meta-common/PersonReference> a owl:Class ;
    rdfs:label "PersonReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/labelLong> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/groupLabel> ],
        <https://ld.ech.ch/schema/0292/meta-common/HasIdentification> ;
    skos:definition """Lightweight reference to a person with key identification data at time of linking. Preserves historical accuracy even if the person changes later.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Leichtgewichtige Referenz auf eine Person mit den wichtigsten Identifikationsmerkmalen zum Zeitpunkt der Verknüpfung. Ermöglicht historische Korrektheit auch wenn sich die Person später ändert.
""" .

<https://ld.ech.ch/schema/0292/meta-common/multilingualValue> a owl:ObjectProperty ;
    rdfs:label "multilingual_value" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:definition """A multilingual value with language specification.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Ein mehrsprachiger Wert mit Angabe der Sprache.
""" .

<https://ld.ech.ch/schema/0292/meta-common/IsEventWithDuration> a owl:Class ;
    rdfs:label "IsEventWithDuration" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginPlanned> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeBeginActual> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> ] ;
    skos:definition """A mixin class that provides slots for modeling events or occurrences with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine Mixin-Klasse, die Slots für die Modellierung von Ereignissen oder Vorkommnissen mit Zeitdauer zur Verfügung stellt.
""" .

tutorial:Session a owl:Class ;
    rdfs:label "Session" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
            owl:onProperty <http://schema.org/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateEndActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:agendaItem ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <http://schema.org/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/dateBeginActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom tutorial:AgendaItem ;
            owl:onProperty tutorial:agendaItem ] ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

<https://ch.paf.link/schema/tutorial/results/no> a owl:Class ;
    rdfs:label "no" ;
    rdfs:subClassOf tutorial:ResultEnum .

<https://ch.paf.link/schema/tutorial/results/yes> a owl:Class ;
    rdfs:label "yes" ;
    rdfs:subClassOf tutorial:ResultEnum .

tutorial:session a owl:ObjectProperty ;
    rdfs:label "sessions" ;
    rdfs:range tutorial:Session ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

<https://ld.ech.ch/schema/0292/meta-common/abbreviation> a owl:ObjectProperty ;
    rdfs:label "abbreviation" ;
    rdfs:range <https://ld.ech.ch/schema/0292/meta-common/MultilingualValue> ;
    skos:definition """Abbreviation (can be multilingual).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Abkürzung (kann mehrsprachig sein).
""" .

<http://schema.org/validFrom> a owl:DatatypeProperty ;
    rdfs:label "valid_from" ;
    rdfs:range xsd:date ;
    skos:definition """The date from which the information is valid.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das Datum, ab dem die Information gültig ist.
""" .

<http://schema.org/validThrough> a owl:DatatypeProperty ;
    rdfs:label "valid_through" ;
    rdfs:range xsd:date ;
    skos:definition """The date until which the information is valid, inclusive.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das Datum, bis und mit dem die Information gültig ist.
""" .

tutorial:Vote a owl:Class ;
    rdfs:label "Vote" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty tutorial:question ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:is_part_of ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:is_part_of ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:question ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty tutorial:question ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty tutorial:is_part_of ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:result ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty tutorial:is_part_of_agenda_item ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:result ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty tutorial:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty tutorial:is_part_of_agenda_item ],
        [ a owl:Restriction ;
            owl:allValuesFrom tutorial:AgendaItem ;
            owl:onProperty tutorial:is_part_of_agenda_item ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/datetimeActual> ],
        [ a owl:Restriction ;
            owl:allValuesFrom tutorial:ResultEnum ;
            owl:onProperty tutorial:result ] ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:is_part_of a owl:DatatypeProperty ;
    rdfs:label "is_part_of" ;
    rdfs:range xsd:anyURI ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:is_part_of_agenda_item a owl:ObjectProperty ;
    rdfs:label "is_part_of_agenda_item" ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:question a owl:DatatypeProperty ;
    rdfs:label "question" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

tutorial:result a owl:ObjectProperty ;
    rdfs:label "result" ;
    rdfs:range tutorial:ResultEnum ;
    skos:inScheme <https://ch.paf.link/schema/tutorial> .

<https://ld.ech.ch/schema/0292/meta-common/HasIdentification> a owl:Class ;
    rdfs:label "HasIdentification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/localId> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/wikidataUri> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://ld.ech.ch/schema/0292/meta-common/globalURI> ] ;
    skos:definition """A mixin class that provides slots for the identification of an entity.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Eine Mixin-Klasse, die Slots für die Identifikation einer Entität zur Verfügung stellt.
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateActual> a owl:DatatypeProperty ;
    rdfs:label "date_actual" ;
    rdfs:range xsd:date ;
    skos:definition """The actual date of an instantaneous event or occurrence (without time duration).
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das tatsächliche Datum eines instantanen Ereignisses oder Vorkommnissen (ohne Zeitdauer).
""" .

<https://ld.ech.ch/schema/0292/meta-common/dateBeginPlanned> a owl:DatatypeProperty ;
    rdfs:label "date_begin_planned" ;
    rdfs:range xsd:date ;
    skos:definition """The planned start date of an event or occurrence with time duration.
""" ;
    skos:inScheme <https://ld.ech.ch/schema/0292/meta-common> ;
    tutorial:description_de """Das geplante Startdatum eines Ereignisses oder Vorkommnissen mit Zeitdauer.
""" .

