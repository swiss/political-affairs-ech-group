                "group_label": {
                    "description": "Name of the body/group at time of linking.\n",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "label": {
                    "description": "Mandatory short display name to identify the person within the organisation (e.g. with added birth year to distinguish persons with the same name).\n",
                    "type": "string"
                },
                "label_long": {
                    "description": "Optional long display name including academic titles and full official name (e.g. \"Dr. Maria Muster-Beispiel\").\n",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "local_id": {
                    "description": "Local identifier. For example, a UUID from the council information system.\n",
                    "type": [
                        "string",
                        "null"
                    ]
